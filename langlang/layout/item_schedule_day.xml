<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_day_container"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/v_indicator"
        android:background="#00e5ff"
        android:visibility="invisible"
        android:layout_width="4dp"
        android:layout_height="24dp"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingTop="18dp"
        android:paddingRight="20dp"
        android:paddingBottom="18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_day_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="10dp"
            android:src="@drawable/zho1"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/selector_nav_item_text"
            android:id="@+id/tv_day_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="周一"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:id="@+id/tv_day_en"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon"/>
    </LinearLayout>
</RelativeLayout>
