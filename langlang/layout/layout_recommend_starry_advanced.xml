<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_starry"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_starry"
        android:paddingLeft="24dp"
        android:paddingTop="16dp"
        android:paddingRight="24dp"
        android:paddingBottom="24dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/top_bar_starry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/logo_starry"
                android:layout_width="120dp"
                android:layout_height="32dp"
                android:src="@drawable/sm_logo"
                android:scaleType="fitCenter"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/notice_container_starry"
                android:background="@drawable/shape_notice_bg_starry"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/gonggao"/>
                <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:ellipsize="marquee"
                    android:id="@+id/tv_notice_starry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text=""
                    android:singleLine="true"
                    android:layout_weight="1"
                    android:marqueeRepeatLimit="marquee_forever"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/top_right_starry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12sp"
                    android:textColor="#b3ffffff"
                    android:id="@+id/tv_weather_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""/>
                <ImageView
                    android:id="@+id/iv_wifi_starry"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/wifi"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_time_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="12:00"/>
            </LinearLayout>
        </LinearLayout>
        <HorizontalScrollView
            android:id="@+id/category_scroll_starry"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/category_container_starry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
        <FrameLayout
            android:id="@+id/hero_container_starry"
            android:background="@drawable/selector_card_starry"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@+id/func_search_starry"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginLeft="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="24dp">
            <com.shenma.tvlauncher.view.RoundCornerImageView
                android:id="@+id/hero_img_starry"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <View
                android:id="@+id/hero_gradient_starry"
                android:background="@drawable/bg_gradient_hero_starry"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_gravity="top|left"
                android:id="@+id/hero_badge_starry"
                android:background="@drawable/shape_badge_starry"
                android:paddingLeft="12dp"
                android:paddingTop="4dp"
                android:paddingRight="12dp"
                android:paddingBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="14dp"
                android:text="推荐"/>
            <LinearLayout
                android:layout_gravity="bottom|left"
                android:orientation="vertical"
                android:id="@+id/hero_text_container_starry"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp">
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:ellipsize="end"
                    android:id="@+id/hero_title_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:maxLines="1"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="bottom|center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/hero_indicators_starry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/dashboard_row_starry"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_search_starry"
                android:background="@drawable/selector_func_search_starry"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusRight="@+id/func_favorite_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/func_search_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_searchs"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="搜索"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_favorite_starry"
                android:background="@drawable/selector_func_favorite_starry"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/func_search_starry"
                android:nextFocusRight="@+id/func_user_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/func_favorite_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_heart_white"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="收藏"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_user_starry"
                android:background="@drawable/selector_func_user_starry"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/func_favorite_starry"
                android:nextFocusRight="@+id/func_setting_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/func_user_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_user_new"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="个人中心"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_setting_starry"
                android:background="@drawable/selector_func_setting_starry"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/func_user_starry"
                android:nextFocusRight="@+id/func_clear_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/func_setting_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/setting"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="设置"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_clear_starry"
                android:background="@drawable/selector_func_clear_starry"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/func_setting_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/func_clear_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clear"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="清除缓存"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_about_starry"
                android:background="@drawable/selector_func_about_starry"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/func_clear_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/func_about_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/gy"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="关于我们"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:background="#007aff"
                    android:layout_width="4dp"
                    android:layout_height="18dp"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/title_history_starry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="继续观看"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#8a8d96"
                    android:id="@+id/btn_history_more_starry"
                    android:background="@drawable/selector_card_starry"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusDown="@+id/btn_recommend_more_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="查看更多"/>
            </LinearLayout>
            <HorizontalScrollView
                android:id="@+id/hsv_history_starry"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/history_container_starry"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/recommend_section_starry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:background="#ff6b6b"
                    android:layout_width="4dp"
                    android:layout_height="18dp"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/title_recommend_starry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="电影"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#8a8d96"
                    android:id="@+id/btn_recommend_more_starry"
                    android:background="@drawable/selector_card_starry"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@+id/btn_history_more_starry"
                    android:nextFocusDown="@+id/btn_recommend_tv_more_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更多"/>
            </LinearLayout>
            <HorizontalScrollView
                android:id="@+id/hsv_recommend_starry"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/recommended_container_starry"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/recommend_section_tv_starry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:background="#ff6b6b"
                    android:layout_width="4dp"
                    android:layout_height="18dp"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/title_recommend_tv_starry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="电视剧"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#8a8d96"
                    android:id="@+id/btn_recommend_tv_more_starry"
                    android:background="@drawable/selector_card_starry"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@+id/btn_recommend_more_starry"
                    android:nextFocusDown="@+id/btn_recommend_comic_more_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更多"/>
            </LinearLayout>
            <HorizontalScrollView
                android:id="@+id/hsv_recommend_tv_starry"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/recommended_container_tv_starry"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/recommend_section_comic_starry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:background="#ff6b6b"
                    android:layout_width="4dp"
                    android:layout_height="18dp"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/title_recommend_comic_starry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="动漫"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#8a8d96"
                    android:id="@+id/btn_recommend_comic_more_starry"
                    android:background="@drawable/selector_card_starry"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@+id/btn_recommend_tv_more_starry"
                    android:nextFocusDown="@+id/btn_recommend_variety_more_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更多"/>
            </LinearLayout>
            <HorizontalScrollView
                android:id="@+id/hsv_recommend_comic_starry"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/recommended_container_comic_starry"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/recommend_section_variety_starry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:background="#ff6b6b"
                    android:layout_width="4dp"
                    android:layout_height="18dp"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/title_recommend_variety_starry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="综艺"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="#8a8d96"
                    android:id="@+id/btn_recommend_variety_more_starry"
                    android:background="@drawable/selector_card_starry"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@+id/btn_recommend_comic_more_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更多"/>
            </LinearLayout>
            <HorizontalScrollView
                android:id="@+id/hsv_recommend_variety_starry"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/recommended_container_variety_starry"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:background="#ff6b6b"
                    android:layout_width="4dp"
                    android:layout_height="18dp"/>
                <TextView
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/title_hot_starry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="热播排行"/>
            </LinearLayout>
            <HorizontalScrollView
                android:id="@+id/hsv_hot_starry"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/hot_container_starry"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
