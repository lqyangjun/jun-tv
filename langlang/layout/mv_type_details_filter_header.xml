<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="@dimen/sm_5"
    android:paddingBottom="@dimen/sm_5"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="@dimen/sm_20"
        android:paddingTop="@dimen/sm_2"
        android:paddingRight="@dimen/sm_20"
        android:paddingBottom="@dimen/sm_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sm_28"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/sm_10"
            android:text="类型："
            android:singleLine="true"/>
        <HorizontalScrollView
            android:gravity="center_vertical"
            android:scrollbars="none"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fillViewport="false"
            android:layout_weight="1"
            android:fadeScrollbars="false">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/filter_type_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="@dimen/sm_20"
        android:paddingTop="@dimen/sm_2"
        android:paddingRight="@dimen/sm_20"
        android:paddingBottom="@dimen/sm_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sm_28"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/sm_10"
            android:text="年份："
            android:singleLine="true"/>
        <HorizontalScrollView
            android:gravity="center_vertical"
            android:scrollbars="none"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fillViewport="false"
            android:layout_weight="1"
            android:fadeScrollbars="false">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/filter_year_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="@dimen/sm_20"
        android:paddingTop="@dimen/sm_2"
        android:paddingRight="@dimen/sm_20"
        android:paddingBottom="@dimen/sm_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sm_28"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/sm_10"
            android:text="地区："
            android:singleLine="true"/>
        <HorizontalScrollView
            android:gravity="center_vertical"
            android:scrollbars="none"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fillViewport="false"
            android:layout_weight="1"
            android:fadeScrollbars="false">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/filter_area_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="@dimen/sm_20"
        android:paddingTop="@dimen/sm_2"
        android:paddingRight="@dimen/sm_20"
        android:paddingBottom="@dimen/sm_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sm_28"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/sm_10"
            android:text="排序："
            android:singleLine="true"/>
        <HorizontalScrollView
            android:gravity="center_vertical"
            android:scrollbars="none"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fillViewport="false"
            android:layout_weight="1"
            android:fadeScrollbars="false">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/filter_sort_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>
