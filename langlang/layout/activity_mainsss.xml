<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/fl_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/rl_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/mains"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_65"
                android:layout_marginTop="@dimen/sm_15"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:gravity="center"
                    android:layout_width="@dimen/sm_270"
                    android:layout_height="@dimen/sm_46"
                    android:layout_marginLeft="@dimen/sm_5"
                    android:layout_marginTop="@dimen/sm_0"
                    android:layout_alignParentLeft="true">
                    <LinearLayout
                        android:id="@+id/home_top_searchs"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:nextFocusRight="@+id/home_top_records"
                        android:nextFocusDown="@+id/rb_recommend"
                        android:clickable="true"
                        android:descendantFocusability="blocksDescendants"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sm_46"
                        android:layout_marginRight="@dimen/sm_10"
                        style="@style/home_top_LinearLayouts">
                        <ImageView
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:layout_marginRight="@dimen/sm_5"
                            android:src="@drawable/ic_searchs"/>
                        <TextView
                            android:textSize="@dimen/sm_19"
                            android:textColor="@color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/search"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/home_top_records"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/home_top_searchs"
                        android:nextFocusDown="@+id/rb_recommend"
                        android:clickable="true"
                        android:descendantFocusability="blocksDescendants"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sm_46"
                        style="@style/home_top_LinearLayouts">
                        <ImageView
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:layout_marginRight="@dimen/sm_5"
                            android:src="@drawable/ic_history"/>
                        <TextView
                            android:textSize="@dimen/sm_18"
                            android:textColor="@color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/history"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:background="@drawable/gonggao_root_bg"
                    android:layout_width="@dimen/sm_600"
                    android:layout_height="@dimen/sm_46"
                    android:layout_marginTop="@dimen/sm_2">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:id="@+id/gonggao_root"
                        android:layout_width="@dimen/sm_640"
                        android:layout_height="@dimen/sm_46">
                        <ImageView
                            android:layout_width="@dimen/sm_38"
                            android:layout_height="@dimen/sm_38"
                            android:layout_marginLeft="@dimen/sm_5"
                            android:layout_marginRight="@dimen/sm_10"
                            android:src="@drawable/gonggao"/>
                        <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/white"
                            android:ellipsize="marquee"
                            android:gravity="center_vertical"
                            android:id="@+id/gonggao"
                            android:layout_width="@dimen/sm_550"
                            android:layout_height="match_parent"
                            android:layout_marginRight="@dimen/sm_30"
                            android:text=""
                            android:singleLine="true"
                            android:marqueeRepeatLimit="marquee_forever"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/main"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/sm_76"
                    android:layout_marginLeft="@dimen/sm_5"
                    android:layout_alignParentTop="true">
                    <ImageView
                        android:id="@+id/iv_net_state"
                        android:layout_width="@dimen/sm_35"
                        android:layout_height="@dimen/sm_35"
                        android:layout_marginTop="@dimen/sm_2"
                        android:layout_marginRight="@dimen/sm_10"
                        android:src="@drawable/wifi"/>
                    <RelativeLayout
                        android:layout_gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sm_2">
                        <TextView
                            android:textSize="@dimen/sm_25"
                            android:textStyle="normal"
                            android:textColor="@color/white"
                            android:id="@+id/tv_main_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/def_time"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:textSize="@dimen/sm_25"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/time_colon"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxHeight="@dimen/sm_76"
                            android:text="@string/time_colon"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                    <ImageView
                        android:id="@+id/iv_main_line"
                        android:layout_width="@dimen/sm_25"
                        android:layout_height="@dimen/sm_50"
                        android:layout_marginTop="@dimen/sm_2"
                        android:src="@drawable/home_line"/>
                    <TextView
                        android:textSize="@dimen/sm_18"
                        android:id="@+id/tv_main_date"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/def_date"/>
                    <ImageView
                        android:id="@+id/logo"
                        android:layout_width="@dimen/sm_152"
                        android:layout_height="@dimen/sm_35"
                        android:layout_marginTop="@dimen/sm_2"
                        android:src="@drawable/sm_logo"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_rb"
                android:paddingLeft="@dimen/sm_185"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_50"
                android:layout_marginTop="@dimen/sm_20"
                android:layout_below="@+id/mains">
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/title_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton
                        android:gravity="center"
                        android:id="@+id/rb_recommend"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/rb_settings"
                        android:nextFocusRight="@+id/rb_video_type"
                        android:nextFocusDown="@+id/iv_re_0"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:text="@string/recommend"
                        android:layout_weight="0.5"
                        style="@style/TitleButton"/>
                    <RadioButton
                        android:gravity="center"
                        android:id="@+id/rb_video_type"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/rb_recommend"
                        android:nextFocusRight="@+id/rb_settings"
                        android:nextFocusDown="@+id/topic_iv_0"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:text="@string/video_type"
                        android:layout_weight="0.5"
                        style="@style/TitleButton"/>
                    <RadioButton
                        android:gravity="center"
                        android:id="@+id/rb_settings"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/rb_video_type"
                        android:nextFocusRight="@+id/rb_recommend"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:text="@string/settings"
                        android:layout_weight="0.5"
                        style="@style/TitleButton"/>
                </RadioGroup>
                <ImageView
                    android:id="@+id/iv_titile"
                    android:layout_width="@dimen/sm_120"
                    android:layout_height="@dimen/sm_10"
                    android:layout_marginLeft="@dimen/sm_125"
                    android:layout_marginBottom="@dimen/sm_2"
                    android:src="@drawable/titile_top"
                    android:layout_alignParentBottom="true"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/rg_video_type_bottoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sm_43"
                android:layout_marginTop="@dimen/sm_0"
                android:layout_marginRight="@dimen/sm_42"
                android:layout_below="@+id/mains">
                <LinearLayout
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <HorizontalScrollView
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioGroup
                            android:orientation="horizontal"
                            android:id="@+id/rg_video_type_bottom"
                            android:layout_width="@dimen/sm_60"
                            android:layout_height="wrap_content"/>
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>
            <ScrollView
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:layout_below="@+id/rg_video_type_bottoms">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <android.support.v4.view.ViewPager
                        android:id="@+id/pager"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sm_500"
                        android:layout_marginTop="@dimen/sm_0"
                        android:layout_below="@+id/rg_video_type_bottoms"/>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sm_70"
                        android:layout_marginTop="@dimen/sm_4"
                        android:layout_marginBottom="@dimen/sm_5"
                        android:layout_below="@+id/pager"
                        android:layout_alignParentBottom="true">
                        <LinearLayout
                            android:id="@+id/home_user"
                            android:tag="wnicheng"
                            android:layout_marginLeft="@dimen/sm_30"
                            style="@style/home_bottom_LinearLayout">
                            <ImageView
                                android:layout_width="@dimen/sm_38"
                                android:layout_height="@dimen/sm_38"
                                android:layout_marginRight="@dimen/sm_5"
                                android:src="@drawable/ic_user"/>
                            <TextView
                                android:textColor="@color/white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/Personal_Center"
                                style="@style/bottom_TitleButton"/>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/home_collect"
                            style="@style/home_bottom_LinearLayout">
                            <ImageView
                                android:layout_width="@dimen/sm_38"
                                android:layout_height="@dimen/sm_38"
                                android:layout_marginRight="@dimen/sm_5"
                                android:src="@drawable/ic_collect"/>
                            <TextView
                                android:textColor="@color/white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/Personalized_settings"
                                style="@style/bottom_TitleButton"/>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/home_play_set"
                            style="@style/home_bottom_LinearLayout">
                            <ImageView
                                android:layout_width="@dimen/sm_38"
                                android:layout_height="@dimen/sm_38"
                                android:layout_marginRight="@dimen/sm_5"
                                android:src="@drawable/ic_set"/>
                            <TextView
                                android:textColor="@color/white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/Playback_Settings"
                                style="@style/bottom_TitleButton"/>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/home_clear"
                            style="@style/home_bottom_LinearLayout">
                            <ImageView
                                android:layout_width="@dimen/sm_38"
                                android:layout_height="@dimen/sm_38"
                                android:layout_marginRight="@dimen/sm_5"
                                android:src="@drawable/ic_clear"/>
                            <TextView
                                android:textColor="@color/white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/Clean_up_records"
                                style="@style/bottom_TitleButton"/>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/home_wallpaper"
                            style="@style/home_bottom_LinearLayout">
                            <ImageView
                                android:layout_width="@dimen/sm_38"
                                android:layout_height="@dimen/sm_38"
                                android:layout_marginRight="@dimen/sm_5"
                                android:src="@drawable/ic_wallpaper"/>
                            <TextView
                                android:textColor="@color/white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/About_Us"
                                style="@style/bottom_TitleButton"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/notice"
                android:background="@android:color/transparent"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true">
                <ImageView
                    android:id="@+id/notice_iamge_url"
                    android:layout_width="@dimen/sm_750"
                    android:layout_height="@dimen/sm_500"
                    android:scaleType="fitXY"
                    android:layout_centerInParent="true"/>
                <TextView
                    android:textSize="@dimen/sm_20"
                    android:textColor="@color/white"
                    android:id="@+id/notice_button"
                    android:background="@drawable/button_1"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/sm_10"
                    android:layout_marginBottom="@dimen/sm_10"
                    android:text="@string/returns"
                    android:layout_alignRight="@+id/notice_iamge_url"
                    android:layout_alignBottom="@+id/notice_iamge_url"/>
            </RelativeLayout>
        </RelativeLayout>
    </FrameLayout>
    <TextView
        android:textSize="@dimen/sm_18"
        android:textColor="@color/detail_point"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tv_update_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_80"/>
</FrameLayout>
