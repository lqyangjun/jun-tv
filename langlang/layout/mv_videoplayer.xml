<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <tv.danmaku.ijk.media.example.widget.media.IjkVideoView
        android:id="@+id/i_video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"/>
    <TableLayout
        android:id="@+id/hubview"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_forfend"
        android:background="@drawable/button_normal_bgs"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/Ad_block_up"
        android:background="@drawable/button_normal_bgs"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="@dimen/sm_70"/>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:id="@+id/Ad_block_down"
        android:background="@drawable/button_normal_bgs"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="@dimen/sm_70"/>
    <LinearLayout
        android:layout_gravity="end|bottom"
        android:orientation="horizontal"
        android:id="@+id/Ad_block_right"
        android:background="@drawable/button_normal_bgb"
        android:visibility="invisible"
        android:layout_width="@dimen/sm_250"
        android:layout_height="@dimen/sm_250"/>
    <RelativeLayout
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/ll_epg1"
        android:paddingBottom="@dimen/sm_30"
        android:visibility="visible"
        android:layout_width="@dimen/sm_900"
        android:layout_height="@dimen/sm_300">
        <View
            android:id="@+id/view_bg"
            android:background="@drawable/bg_bottom_epg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sm_150"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/left_container"
            android:layout_width="@dimen/sm_250"
            android:layout_height="wrap_content"
            android:layout_marginLeft="0dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true">
            <com.view.MarqueeTextView
                android:textSize="@dimen/sm_120"
                android:textStyle="bold"
                android:textColor="@color/epg"
                android:ellipsize="marquee"
                android:gravity="center"
                android:id="@+id/tv_channelnum1"
                android:paddingTop="@dimen/sm_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:singleLine="true"
                android:shadowColor="#cc000000"
                android:shadowDx="5"
                android:shadowRadius="5"
                android:marqueeRepeatLimit="marquee_forever"/>
            <com.view.MarqueeTextView
                android:textSize="@dimen/sm_48"
                android:textColor="@color/epg"
                android:ellipsize="marquee"
                android:gravity="center"
                android:id="@+id/tv_channelname1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-10dp"
                android:text=""
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/right_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sm_0"
            android:layout_marginRight="@dimen/sm_30"
            android:layout_marginBottom="@dimen/sm_20"
            android:layout_toRightOf="@+id/left_container"
            android:layout_alignParentBottom="true">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sm_5">
                <TextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/white"
                    android:id="@+id/tv_current_program"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前节目："/>
                <TextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/white"
                    android:id="@+id/tv_current_program_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="精彩节目"/>
                <com.view.ScrollTextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/white"
                    android:ellipsize="marquee"
                    android:id="@+id/tv_current_program_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_15"
                    android:text=""
                    android:singleLine="true"
                    android:layout_weight="1"
                    android:marqueeRepeatLimit="marquee_forever"/>
                <TextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/white"
                    android:id="@+id/tv_current_program_suffix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_10"
                    android:text="频道列表"
                    android:singleLine="true"
                    android:drawableLeft="@drawable/setting"/>
            </LinearLayout>
            <View
                android:id="@+id/view_line"
                android:background="@color/darkwhite"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_5"
                android:layout_marginBottom="@dimen/sm_5"/>
            <com.shenma.tvlauncher.view.smoothprogressbar.SmoothProgressBar
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_4"
                android:layout_marginBottom="@dimen/sm_5"
                android:indeterminate="true"
                app:spb_color="@color/title_top"
                app:spb_mirror_mode="false"
                app:spb_progressiveStart_activated="true"
                app:spb_progressiveStart_speed="2.5"
                app:spb_progressiveStop_speed="3.4"
                app:spb_reversed="false"
                app:spb_sections_count="1"
                app:spb_speed="2"
                app:spb_stroke_separator_length="@dimen/sm_450"
                app:spb_stroke_width="@dimen/sm_4"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/epg"
                    android:id="@+id/tv_next_program"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="下一节目："/>
                <TextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/epg"
                    android:id="@+id/tv_next_program_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="精彩节目"/>
                <com.view.MarqueeTextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/epg"
                    android:ellipsize="marquee"
                    android:id="@+id/tv_next_program_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_15"
                    android:text=""
                    android:singleLine="true"
                    android:layout_weight="1"
                    android:marqueeRepeatLimit="marquee_forever"/>
                <TextView
                    android:textSize="@dimen/sm_32"
                    android:textColor="@color/epg"
                    android:id="@+id/tv_next_program_suffix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_0"
                    android:text="换源"
                    android:singleLine="true"
                    android:drawableLeft="@drawable/channellist"
                    android:drawablePadding="@dimen/sm_5"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/sm_20"
            android:textColor="@color/white"
            android:id="@+id/tv_srcinfo1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_60"
            android:layout_marginRight="@dimen/sm_10"
            android:text="源:1/1"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <LinearLayout
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/ll_epg2"
        android:background="@drawable/button_normal_bg"
        android:paddingLeft="@dimen/sm_60"
        android:paddingTop="@dimen/sm_10"
        android:paddingRight="@dimen/sm_60"
        android:paddingBottom="@dimen/sm_10"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sm_30">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sm_50"
                    android:textStyle="bold"
                    android:textColor="@color/screen_bg"
                    android:id="@+id/tv_channelnum2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_35"
                    android:text=""/>
                <com.view.ScrollTextView
                    android:textSize="@dimen/sm_40"
                    android:textColor="@color/screen_bg"
                    android:ellipsize="marquee"
                    android:gravity="start"
                    android:id="@+id/tv_channelname2"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_15"
                    android:text=""
                    android:singleLine="true"
                    android:marqueeRepeatLimit="marquee_forever"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="start"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textColor="@color/screen_bg"
                    android:gravity="center"
                    android:padding="@dimen/sm_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 频道列表   "
                    android:drawableLeft="@drawable/setting"/>
                <TextView
                    android:textColor="@color/screen_bg"
                    android:gravity="center"
                    android:padding="@dimen/sm_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 换源"
                    android:drawableLeft="@drawable/channellist"/>
                <TextView
                    android:textColor="@color/screen_bg"
                    android:gravity="start|center_vertical"
                    android:id="@+id/tv_srcinfo2"
                    android:padding="@dimen/sm_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_20"
                    android:text=""/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_epginfo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/sm_30"
            android:layout_weight="2">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <TextView
                    android:textColor="@color/screen_bg"
                    android:id="@+id/tv_curepg_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前节目："/>
                <com.view.ScrollTextView
                    android:textColor="@color/screen_bg"
                    android:ellipsize="end"
                    android:id="@+id/tv_epgcurrent"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="精彩节目"
                    android:singleLine="true"
                    android:marqueeRepeatLimit="marquee_forever"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <FrameLayout
                    android:background="@color/darkwhite"
                    android:layout_width="@dimen/sm_350"
                    android:layout_height="@dimen/sm_5">
                    <com.shenma.tvlauncher.view.smoothprogressbar.SmoothProgressBar
                        android:layout_width="@dimen/sm_340"
                        android:layout_height="@dimen/sm_4"
                        android:layout_marginLeft="@dimen/sm_5"
                        android:layout_marginRight="@dimen/sm_5"
                        android:indeterminate="true"
                        app:spb_color="@color/title_top"
                        app:spb_mirror_mode="false"
                        app:spb_progressiveStart_activated="true"
                        app:spb_progressiveStart_speed="2.5"
                        app:spb_progressiveStop_speed="3.4"
                        app:spb_reversed="false"
                        app:spb_sections_count="1"
                        app:spb_speed="2"
                        app:spb_stroke_separator_length="@dimen/sm_450"
                        app:spb_stroke_width="@dimen/sm_4"/>
                </FrameLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <TextView
                    android:textColor="@color/screen_bg"
                    android:id="@+id/tv_nextepg_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="下个节目："/>
                <com.view.ScrollTextView
                    android:textColor="@color/screen_bg"
                    android:ellipsize="end"
                    android:id="@+id/tv_epgnext"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="精彩节目"
                    android:singleLine="true"
                    android:marqueeRepeatLimit="marquee_forever"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <com.shenma.tvlauncher.view.PlayerProgressBar
            android:layout_gravity="center_horizontal"
            android:id="@+id/progressBar"
            android:layout_width="@dimen/sm_100"
            android:layout_height="@dimen/sm_100"
            android:indeterminate="false"
            android:indeterminateDrawable="@drawable/loadingprogress"/>
    </LinearLayout>
    <com.shenma.tvlauncher.p008ui.ProgressLayout
        android:layout_gravity="center"
        android:id="@+id/progress_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <TextView
        android:textSize="@dimen/sm_48"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textColorHighlight="@color/white"
        android:layout_gravity="start|center_vertical"
        android:id="@+id/tv_progress_time"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sm_20"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/tv_notice_root"
        android:background="@drawable/gonggao_root_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/sm_46"
        android:layout_marginLeft="@dimen/sm_43"
        android:layout_marginTop="@dimen/sm_10"
        android:layout_marginRight="@dimen/sm_42"
        android:layout_marginBottom="@dimen/sm_15">
        <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
            android:textSize="@dimen/sm_28"
            android:textColor="@color/white"
            android:ellipsize="marquee"
            android:id="@+id/tv_notice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/tv_logo"
        android:visibility="gone"
        android:layout_width="@dimen/sm_152"
        android:layout_height="@dimen/sm_45"
        android:layout_marginLeft="@dimen/sm_1092"
        android:layout_marginTop="@dimen/sm_20"/>
    <TextView
        android:textSize="@dimen/sm_24"
        android:textColor="#ffffff"
        android:layout_gravity="start|top"
        android:id="@+id/tv_resolution_small"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sm_20"
        android:layout_marginTop="@dimen/sm_20"
        android:text=""/>
    <WebView
        android:id="@+id/webview"
        android:visibility="gone"
        android:layout_width="@dimen/sm_400"
        android:layout_height="@dimen/sm_400"/>
    <TextView
        android:textSize="@dimen/sm_48"
        android:textStyle="bold"
        android:layout_gravity="top|right"
        android:id="@+id/program_nums"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_50"
        android:layout_marginRight="@dimen/sm_30"
        android:text=""/>
    <com.view.MarqueeTextView
        android:textSize="@dimen/sm_120"
        android:textStyle="bold"
        android:textColor="@color/epg"
        android:ellipsize="marquee"
        android:gravity="center"
        android:layout_gravity="top|right"
        android:id="@+id/program_num"
        android:paddingTop="@dimen/sm_5"
        android:layout_width="@dimen/sm_340"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_50"
        android:text=""
        android:singleLine="true"
        android:shadowColor="#cc000000"
        android:shadowDx="5"
        android:shadowRadius="5"
        android:marqueeRepeatLimit="marquee_forever"
        app:layout_constraintBottom_toTopOf="@+id/guideline25"
        app:layout_constraintEnd_toStartOf="@+id/guideline23"
        app:layout_constraintStart_toStartOf="@+id/guideline21"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textColor="#fff"
        android:layout_gravity="end|bottom"
        android:id="@+id/tv_netspeedinfo"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="5dp"
        android:layout_marginBottom="5dp"/>
</FrameLayout>
