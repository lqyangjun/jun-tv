<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/member"
    android:background="#0f1014"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/left_panel"
        android:background="#00000000"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="35">
        <ScrollView
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <LinearLayout
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/iv_member"
                        android:background="@drawable/shape_avatar_purple_gradient_ring"
                        android:padding="3dp"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/user_icon1"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp">
                        <TextView
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no_login"/>
                        <TextView
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/tv_user_vip_badge"
                            android:background="@drawable/bg_badge_normal"
                            android:paddingLeft="10dp"
                            android:paddingTop="3dp"
                            android:paddingRight="10dp"
                            android:paddingBottom="3dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="普通用户"/>
                    </LinearLayout>
                </LinearLayout>
                <RadioGroup
                    android:id="@+id/rg_member"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="20dp"
                    android:layout_weight="1">
                    <RadioButton
                        android:id="@+id/rb_user"
                        android:text="@string/My_Account"
                        android:drawableLeft="@drawable/wd"
                        style="@style/user_leftbar_new"/>
                    <RadioButton
                        android:id="@+id/rb_user_alert"
                        android:layout_marginTop="10dp"
                        android:text="@string/My_TV_series"
                        android:drawableLeft="@drawable/zj"
                        style="@style/user_leftbar_new"/>
                    <RadioButton
                        android:id="@+id/rb_user_collect"
                        android:layout_marginTop="10dp"
                        android:text="@string/My_Collection"
                        android:drawableLeft="@drawable/sc"
                        style="@style/user_leftbar_new"/>
                    <RadioButton
                        android:id="@+id/rb_user_history"
                        android:layout_marginTop="10dp"
                        android:text="@string/History_playback"
                        android:drawableLeft="@drawable/bfls"
                        style="@style/user_leftbar_new"/>
                    <RadioButton
                        android:id="@+id/rb_user_app"
                        android:layout_marginTop="10dp"
                        android:text="@string/Authority_Center"
                        android:drawableLeft="@drawable/sqzx"
                        style="@style/user_leftbar_new"/>
                </RadioGroup>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/right_panel"
        android:padding="20dp"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="65">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_account_details"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ScrollView
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="我的账户"/>
                        <TextView
                            android:textSize="20sp"
                            android:textColor="#ffffff"
                            android:ellipsize="marquee"
                            android:id="@+id/tv_login_status"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:singleLine="true"
                            android:marqueeRepeatLimit="marquee_forever"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="#8c8c8e"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="查看您的账户状态、积分与有效期"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:background="@drawable/bg_card_rounded"
                                android:padding="20dp"
                                android:focusable="true"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="25dp"
                                android:layout_marginBottom="25dp"
                                android:minHeight="180dp"
                                android:layout_weight="1">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_history_new"
                                    android:tint="#cccccc"/>
                                <TextView
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="#ffffff"
                                    android:id="@+id/tv_accumulated_time"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="20dp"
                                    android:text="0h"/>
                                <TextView
                                    android:textSize="13sp"
                                    android:textColor="#8c8c8e"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="累计观影"/>
                            </LinearLayout>
                            <LinearLayout
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:background="@drawable/bg_card_rounded"
                                android:padding="20dp"
                                android:focusable="true"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="25dp"
                                android:layout_marginBottom="25dp"
                                android:minHeight="180dp"
                                android:layout_weight="1">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_empty"
                                    android:tint="#cccccc"/>
                                <TextView
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="#ffffff"
                                    android:id="@+id/tv_vip_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="20dp"
                                    android:text="--"/>
                                <TextView
                                    android:textSize="13sp"
                                    android:textColor="#8c8c8e"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="VIP有效期"/>
                            </LinearLayout>
                            <LinearLayout
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:id="@+id/btn_bind_email"
                                android:background="@drawable/selector_account_card"
                                android:padding="20dp"
                                android:focusable="true"
                                android:clickable="true"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="25dp"
                                android:minHeight="180dp"
                                android:layout_weight="1">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_empty"
                                    android:tint="#cccccc"/>
                                <TextView
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="#ffffff"
                                    android:id="@+id/tv_email_binding"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="20dp"
                                    android:text="未绑定"/>
                                <TextView
                                    android:textSize="13sp"
                                    android:textColor="#8c8c8e"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="绑定邮箱"/>
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="vertical"
                                android:id="@+id/btn_logout"
                                android:background="@drawable/selector_logout_card"
                                android:focusable="true"
                                android:clickable="true"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="25dp"
                                android:minHeight="180dp"
                                android:layout_weight="1"
                                android:layerType="software">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_exit_warning"
                                    android:tint="#ffffff"/>
                                <TextView
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#ff4d4f"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="15dp"
                                    android:text="注销登录"/>
                            </LinearLayout>
                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginRight="25dp"
                                android:layout_weight="1"/>
                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/info_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/filter_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="20sp"
                    android:textColor="#ff8c8c8c"
                    android:id="@+id/filter_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <View
                android:layout_width="0dp"
                android:layout_height="1px"
                android:layout_weight="1"/>
            <TextView
                android:textSize="24sp"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_user_description"/>
        </LinearLayout>
        <GridView
            android:gravity="center"
            android:id="@+id/user_type_details_grid"
            android:focusableInTouchMode="true"
            android:visibility="gone"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp"
            android:horizontalSpacing="15dp"
            android:verticalSpacing="15dp"
            android:stretchMode="columnWidth"
            android:numColumns="3"
            android:layout_below="@+id/info_container"/>
        <TextView
            android:textSize="40sp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/tv_no_data"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
</LinearLayout>
