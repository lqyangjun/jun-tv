<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="@dimen/sm_220"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/sm_26"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_15"
        android:text="@string/empower"/>
    <ImageView
        android:id="@+id/users_empower"
        android:layout_width="@dimen/sm_200"
        android:layout_height="@dimen/sm_200"
        android:layout_marginLeft="@dimen/sm_12"
        android:layout_marginTop="@dimen/sm_20"
        android:src="@drawable/icon_loadings"/>
</LinearLayout>
