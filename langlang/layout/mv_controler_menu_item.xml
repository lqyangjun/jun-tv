<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="@dimen/sm_80">
    <ImageView
        android:id="@+id/iv_menu_logo"
        android:visibility="gone"
        android:layout_width="@dimen/sm_90"
        android:layout_height="@dimen/sm_90"
        android:layout_marginLeft="@dimen/sm_20"
        android:scaleType="fitCenter"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="@dimen/sm_30"
        android:textColor="@drawable/live_channel_item_textcolor_selector"
        android:id="@+id/tv_menu_item"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/sm_80"
        android:layout_marginLeft="@dimen/sm_50"
        android:layout_toRightOf="@+id/iv_menu_logo"
        android:layout_centerVertical="true"
        style="@style/marqueeText"/>
</RelativeLayout>
