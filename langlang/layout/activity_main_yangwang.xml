<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fl_main"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/iv_bg_infinity"
        android:background="@drawable/bg_deep_blue_gradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <RelativeLayout
        android:id="@+id/rl_bg"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
    <FrameLayout
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <android.support.v4.view.ViewPager
            android:id="@+id/pager"
            android:background="@android:color/transparent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:id="@+id/top_category_bar"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp">
            <ImageView
                android:id="@+id/logo"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp"/>
            <LinearLayout
                android:id="@+id/title_group"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/top_info_bar"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp">
            <ImageView
                android:id="@+id/iv_net_state"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/tv_main_time"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/time_colon"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp"/>
            <TextView
                android:id="@+id/tv_main_date"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/mains"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <LinearLayout
            android:id="@+id/gonggao_root"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp">
            <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                android:id="@+id/gonggao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ll_rb"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <ImageView
            android:id="@+id/iv_titile"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <LinearLayout
            android:id="@+id/rg_video_type_bottoms"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp">
            <RadioGroup
                android:id="@+id/rg_video_type_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#ff9500"
            android:layout_gravity="center"
            android:id="@+id/tv_update_msg"
            android:background="#cc000000"
            android:padding="20dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:id="@+id/main"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp">
            <ImageView
                android:id="@+id/iv_main_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/notice"
            android:background="@android:color/transparent"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/notice_iamge_url"
                android:layout_width="@dimen/sm_750"
                android:layout_height="@dimen/sm_500"
                android:scaleType="fitXY"
                android:layout_centerInParent="true"/>
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="@color/white"
                android:id="@+id/notice_button"
                android:background="@drawable/button_1"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/sm_10"
                android:layout_marginBottom="@dimen/sm_10"
                android:text="@string/returns"
                android:layout_alignRight="@+id/notice_iamge_url"
                android:layout_alignBottom="@+id/notice_iamge_url"/>
        </RelativeLayout>
    </FrameLayout>
</FrameLayout>
