<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:descendantFocusability="afterDescendants"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <FrameLayout
        android:background="@drawable/empty_frame_bg"
        android:duplicateParentState="true"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="@dimen/sm_160"
        android:layout_height="@dimen/sm_224">
        <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
            android:id="@+id/user_video_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/default_film_img"
            android:scaleType="fitXY"
            app:siRadius="8dp"/>
        <ImageView
            android:id="@+id/user_video_checked"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/sm_20"
            android:textColor="@color/detail_point"
            android:gravity="center"
            android:layout_gravity="bottom"
            android:id="@+id/user_video_state"
            android:background="@drawable/video_textbg_selector"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sm_30"
            style="@style/marqueeText"/>
        <ImageView
            android:id="@+id/item_focus_border"
            android:background="@drawable/selector_card_focus"
            android:focusable="false"
            android:duplicateParentState="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <TextView
        android:textSize="@dimen/sm_22"
        android:textColor="@drawable/video_textcolor_selector"
        android:ellipsize="marquee"
        android:gravity="center_horizontal"
        android:id="@+id/user_video_name"
        android:layout_width="@dimen/sm_160"
        android:layout_height="@dimen/sm_50"
        android:layout_marginTop="@dimen/sm_6"
        android:singleLine="true"
        style="@style/marqueeText"/>
</LinearLayout>
