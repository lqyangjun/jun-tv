<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/video_details_bg"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:paddingRight="@dimen/sm_89"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/sm_12"
            android:paddingTop="@dimen/sm_16"
            android:paddingRight="@dimen/sm_35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sm_46"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sm_2"
                android:text="@string/image_cache"/>
            <ImageView
                android:layout_width="@dimen/sm_10"
                android:layout_height="@dimen/sm_70"
                android:layout_marginLeft="@dimen/sm_10"
                android:src="@drawable/vod_line35"/>
        </LinearLayout>
        <GridView
            android:id="@+id/wallpaper_gv"
            android:paddingTop="@dimen/sm_13"
            android:scrollbars="none"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/sm_90"
            android:layout_marginBottom="@dimen/sm_6"
            android:listSelector="@android:color/transparent"
            android:verticalSpacing="@dimen/sm_5"
            android:stretchMode="columnWidth"
            android:numColumns="5"
            android:smoothScrollbar="true"/>
    </LinearLayout>
</FrameLayout>
