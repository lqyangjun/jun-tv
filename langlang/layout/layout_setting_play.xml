<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/setting_play"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/shape_left_sidebar_bg"
        android:paddingTop="@dimen/sm_50"
        android:layout_width="@dimen/sm_300"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/sm_36"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sm_50"
            android:text="@string/system_settings"/>
        <TextView
            android:textSize="@dimen/sm_26"
            android:textColor="@color/selector_setting_nav_item_text"
            android:gravity="center_vertical"
            android:id="@+id/nav_play_setting"
            android:background="@drawable/selector_setting_nav_item_bg"
            android:paddingLeft="@dimen/sm_20"
            android:focusable="true"
            android:layout_width="@dimen/sm_240"
            android:layout_height="@dimen/sm_60"
            android:layout_marginBottom="@dimen/sm_20"
            android:text="@string/Playback_Settings"
            android:drawableLeft="@drawable/ic_play_arrow_white"
            android:drawablePadding="@dimen/sm_10">
            <requestFocus/>
        </TextView>
        <TextView
            android:textSize="@dimen/sm_26"
            android:textColor="@color/selector_setting_nav_item_text"
            android:gravity="center_vertical"
            android:id="@+id/nav_network_check"
            android:background="@drawable/selector_setting_nav_item_bg"
            android:paddingLeft="@dimen/sm_20"
            android:focusable="true"
            android:layout_width="@dimen/sm_240"
            android:layout_height="@dimen/sm_60"
            android:layout_marginBottom="@dimen/sm_20"
            android:text="@string/network_test_speed_test"
            android:drawableLeft="@drawable/ic_exit_warning"
            android:drawablePadding="@dimen/sm_10"/>
        <TextView
            android:textSize="@dimen/sm_26"
            android:textColor="@color/selector_setting_nav_item_text"
            android:gravity="center_vertical"
            android:id="@+id/nav_about_device"
            android:background="@drawable/selector_setting_nav_item_bg"
            android:paddingLeft="@dimen/sm_20"
            android:focusable="true"
            android:layout_width="@dimen/sm_240"
            android:layout_height="@dimen/sm_60"
            android:text="@string/about_device"
            android:drawableLeft="@drawable/ic_user_new"
            android:drawablePadding="@dimen/sm_10"/>
    </LinearLayout>
    <RelativeLayout
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <ScrollView
            android:id="@+id/sv_play_setting"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/play_setting_content"
                android:layout_width="@dimen/sm_850"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sm_30"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_20"
                    android:layout_marginBottom="@dimen/sm_20"
                    android:text="@string/Playback_Settings"/>
                <RelativeLayout
                    android:id="@+id/play_setting_content_core"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_core"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_core_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_core_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_core_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_live_core"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_live_core"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_live_core_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_live_core_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_live_core_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_senior"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_senior"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_senior_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_senior_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_senior_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_decode"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_decode"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_decode_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_decode_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_decode_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_playratio"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_playratio"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_playratio_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_playratio_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_playratio_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_jump"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_jump"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_jump_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_jump_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_jump_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_jump_end"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/nav_play_setting"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80"
                    android:layout_marginBottom="@dimen/sm_20">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_setting_jump_end"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_jump_end_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_jump_end_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_jump_end_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/play_setting_content_theme"
                    android:background="@drawable/selector_play_setting_grid_item"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingRight="@dimen/sm_20"
                    android:focusable="true"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_80">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/diy_theme"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_play_setting_control_bg"
                        android:paddingLeft="@dimen/sm_10"
                        android:paddingTop="@dimen/sm_4"
                        android:paddingRight="@dimen/sm_10"
                        android:paddingBottom="@dimen/sm_4"
                        android:duplicateParentState="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        <ImageButton
                            android:id="@+id/play_setting_content_theme_left_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_left_arrows_n"
                            android:scaleType="fitXY"/>
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/selector_play_setting_value_text"
                            android:gravity="center"
                            android:id="@+id/play_setting_content_theme_text"
                            android:duplicateParentState="true"
                            android:layout_width="@dimen/sm_106"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:id="@+id/play_setting_content_theme_right_arrows"
                            android:background="@android:color/transparent"
                            android:layout_width="@dimen/sm_30"
                            android:layout_height="@dimen/sm_30"
                            android:src="@drawable/select_right_arrows_n"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
        </ScrollView>
        <RelativeLayout
            android:id="@+id/network_check_content"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/sm_36"
                android:textColor="#ffffff"
                android:id="@+id/tv_net_check_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_50"
                android:text="检测完成"
                android:layout_centerHorizontal="true"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_net_info_container"
                android:layout_width="@dimen/sm_800"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_30"
                android:layout_below="@+id/tv_net_check_title"
                android:layout_centerHorizontal="true">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_120"
                    android:layout_marginBottom="@dimen/sm_20">
                    <RelativeLayout
                        android:gravity="center"
                        android:background="@drawable/shape_net_test_card_bg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="@dimen/sm_10"
                        android:layout_weight="1">
                        <TextView
                            android:textSize="@dimen/sm_20"
                            android:textColor="#88ffffff"
                            android:id="@+id/tv_net_state_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/sm_10"
                            android:text="连接状态"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/sm_28"
                            android:textColor="#00ff00"
                            android:id="@+id/tv_net_state"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="获取中..."
                            android:layout_below="@+id/tv_net_state_label"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                    <RelativeLayout
                        android:gravity="center"
                        android:background="@drawable/shape_net_test_card_bg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/sm_10"
                        android:layout_weight="1">
                        <TextView
                            android:textSize="@dimen/sm_20"
                            android:textColor="#88ffffff"
                            android:id="@+id/tv_net_delay_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/sm_10"
                            android:text="网络延迟"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/sm_28"
                            android:textColor="#00ff00"
                            android:id="@+id/tv_net_delay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="获取中..."
                            android:layout_below="@+id/tv_net_delay_label"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_120"
                    android:layout_marginBottom="@dimen/sm_20">
                    <RelativeLayout
                        android:gravity="center"
                        android:background="@drawable/shape_net_test_card_bg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="@dimen/sm_10"
                        android:layout_weight="1">
                        <TextView
                            android:textSize="@dimen/sm_20"
                            android:textColor="#88ffffff"
                            android:id="@+id/tv_net_ip_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/sm_10"
                            android:text="本机 IP"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/sm_28"
                            android:textColor="#5588ff"
                            android:id="@+id/tv_net_ip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="获取中..."
                            android:layout_below="@+id/tv_net_ip_label"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                    <RelativeLayout
                        android:gravity="center"
                        android:background="@drawable/shape_net_test_card_bg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/sm_10"
                        android:layout_weight="1">
                        <TextView
                            android:textSize="@dimen/sm_20"
                            android:textColor="#88ffffff"
                            android:id="@+id/tv_net_gateway_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/sm_10"
                            android:text="网关地址"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/sm_28"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/tv_net_gateway"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="获取中..."
                            android:layout_below="@+id/tv_net_gateway_label"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sm_120">
                    <RelativeLayout
                        android:gravity="center"
                        android:background="@drawable/shape_net_test_card_bg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="@dimen/sm_10"
                        android:layout_weight="1">
                        <TextView
                            android:textSize="@dimen/sm_20"
                            android:textColor="#88ffffff"
                            android:id="@+id/tv_net_speed_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/sm_10"
                            android:text="下载速度"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/sm_28"
                            android:textColor="#5588ff"
                            android:id="@+id/tv_net_speed_result"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 KB/s"
                            android:layout_below="@+id/tv_net_speed_label"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                    <RelativeLayout
                        android:gravity="center"
                        android:background="@drawable/shape_net_test_card_bg"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="@dimen/sm_10"
                        android:layout_weight="1">
                        <TextView
                            android:textSize="@dimen/sm_20"
                            android:textColor="#88ffffff"
                            android:id="@+id/tv_net_operator_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/sm_10"
                            android:text="运营商"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/sm_28"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/tv_net_operator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未知"
                            android:layout_below="@+id/tv_net_operator_label"
                            android:layout_centerHorizontal="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
            <Button
                android:textSize="@dimen/sm_24"
                android:textColor="@color/selector_net_test_btn_text"
                android:id="@+id/btn_start_net_check"
                android:background="@drawable/selector_net_test_btn_bg"
                android:focusable="true"
                android:layout_width="@dimen/sm_250"
                android:layout_height="@dimen/sm_80"
                android:layout_marginTop="@dimen/sm_50"
                android:text="重新检测"
                android:layout_below="@+id/ll_net_info_container"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/about_device_content"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/sm_40"
                android:layout_width="@dimen/sm_600"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_100"
                android:layout_centerHorizontal="true">
                <ImageView
                    android:id="@+id/iv_app_icon"
                    android:layout_width="@dimen/sm_150"
                    android:layout_height="@dimen/sm_150"
                    android:layout_marginBottom="@dimen/sm_20"
                    android:src="@drawable/icon"/>
                <TextView
                    android:textSize="@dimen/sm_36"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sm_10"/>
                <TextView
                    android:textSize="@dimen/sm_24"
                    android:textColor="#88ffffff"
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sm_20"
                    android:text="版本: 1.0.0"/>
                <TextView
                    android:textSize="@dimen/sm_24"
                    android:textColor="#aaaaaa"
                    android:id="@+id/tv_mac_address"
                    android:background="@drawable/shape_play_setting_control_bg"
                    android:paddingLeft="@dimen/sm_20"
                    android:paddingTop="@dimen/sm_10"
                    android:paddingRight="@dimen/sm_20"
                    android:paddingBottom="@dimen/sm_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:id="@+id/about_iv"
                    android:layout_width="@dimen/sm_300"
                    android:layout_height="@dimen/sm_300"
                    android:layout_marginTop="@dimen/sm_20"
                    android:scaleType="fitXY"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>
