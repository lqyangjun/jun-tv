<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/media_controler_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/sm_32"
        android:ellipsize="marquee"
        android:layout_gravity="center_vertical"
        android:id="@+id/tv_mv_name"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sm_30"
        android:layout_marginTop="@dimen/sm_5"
        android:maxWidth="@dimen/sm_500"
        android:singleLine="true"
        android:layout_alignParentLeft="true"
        android:marqueeRepeatLimit="1"/>
    <TextView
        android:textSize="@dimen/sm_22"
        android:textColor="#ffffff"
        android:id="@+id/tv_resolution"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sm_15"
        android:layout_marginTop="@dimen/sm_5"
        android:text=""
        android:layout_toRightOf="@+id/tv_mv_name"/>
    <TextView
        android:textSize="@dimen/sm_32"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textColorHighlight="@color/white"
        android:gravity="center_vertical"
        android:id="@+id/tv_time"
        android:paddingRight="@dimen/sm_20"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_5"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
