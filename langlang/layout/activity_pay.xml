<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#ffffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#ff1e90ff"
        android:paddingLeft="@dimen/sm_15"
        android:paddingRight="@dimen/sm_15"
        android:layout_width="match_parent"
        android:layout_height="@dimen/sm_50">
        <Button
            android:textSize="@dimen/sm_22"
            android:textColor="#ffffffff"
            android:id="@+id/pay_back_btn"
            android:background="#44000000"
            android:paddingLeft="@dimen/sm_20"
            android:paddingRight="@dimen/sm_20"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/sm_40"
            android:text="返回"/>
        <TextView
            android:textSize="@dimen/sm_28"
            android:textColor="#ffffffff"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="扫码支付"
            android:layout_weight="1"/>
        <Button
            android:textSize="@dimen/sm_22"
            android:textColor="#ffffffff"
            android:id="@+id/pay_refresh_btn"
            android:background="#44000000"
            android:paddingLeft="@dimen/sm_20"
            android:paddingRight="@dimen/sm_20"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/sm_40"
            android:text="刷新"/>
    </LinearLayout>
    <WebView
        android:id="@+id/pay_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
