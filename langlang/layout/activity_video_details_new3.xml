<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:background="@drawable/video_details_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/video_frame"
        android:background="@android:color/black"
        android:padding="0dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusLeft="@+id/video_frame"
        android:nextFocusRight="@+id/btn_fullscreen"
        android:nextFocusUp="@+id/video_frame"
        android:nextFocusDown="@+id/btn_fullscreen"
        android:clickable="true"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="@dimen/sm_650"
        android:layout_height="@dimen/sm_380"
        android:layout_marginLeft="@dimen/sm_40"
        android:layout_marginTop="@dimen/sm_40"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true">
        <tv.danmaku.ijk.media.example.widget.media.IjkVideoView
            android:id="@+id/i_video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <master.flame.danmaku.p022ui.widget.DanmakuSurfaceView
            android:id="@+id/danmaku_view"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/Ad_block_up"
            android:background="@drawable/button_normal_bgs"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sm_70"/>
        <LinearLayout
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/Ad_block_down"
            android:background="@drawable/button_normal_bgs"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sm_70"/>
        <LinearLayout
            android:layout_gravity="end|bottom"
            android:orientation="horizontal"
            android:id="@+id/Ad_block_right"
            android:background="@drawable/button_normal_bgb"
            android:visibility="invisible"
            android:layout_width="@dimen/sm_250"
            android:layout_height="@dimen/sm_250"/>
        <TableLayout
            android:id="@+id/hubview"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/loading_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.shenma.tvlauncher.view.PlayerProgressBar
                android:layout_gravity="center_horizontal"
                android:id="@+id/progressBar"
                android:layout_width="@dimen/sm_60"
                android:layout_height="@dimen/sm_60"
                android:indeterminate="false"
                android:indeterminateDrawable="@drawable/loadingprogress"/>
        </LinearLayout>
        <com.shenma.tvlauncher.p008ui.ProgressLayout
            android:layout_gravity="center"
            android:id="@+id/progress_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="@dimen/sm_30"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_gravity="start|center_vertical"
            android:id="@+id/tv_progress_time"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sm_20"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="start|top"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sm_20"
            android:layout_marginTop="@dimen/sm_12">
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="@android:color/white"
                android:id="@+id/tv_mv_name"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="#ffffff"
                android:id="@+id/tv_resolution"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sm_15"
                android:text=""/>
        </LinearLayout>
        <WebView
            android:id="@+id/webview"
            android:visibility="gone"
            android:layout_width="@dimen/sm_300"
            android:layout_height="@dimen/sm_300"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="top"
            android:id="@+id/tv_notice_root"
            android:background="@drawable/gonggao_root_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sm_46"
            android:layout_marginLeft="@dimen/sm_43"
            android:layout_marginTop="@dimen/sm_10"
            android:layout_marginRight="@dimen/sm_42">
            <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                android:textSize="@dimen/sm_28"
                android:textColor="@color/white"
                android:ellipsize="marquee"
                android:id="@+id/tv_notice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"/>
        </LinearLayout>
        <ImageView
            android:layout_gravity="end|top"
            android:id="@+id/tv_logo"
            android:visibility="gone"
            android:layout_width="@dimen/sm_152"
            android:layout_height="@dimen/sm_45"
            android:layout_marginTop="@dimen/sm_20"
            android:layout_marginRight="@dimen/sm_20"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/details_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="@dimen/sm_20"
        android:layout_marginRight="@dimen/sm_40"
        android:layout_toRightOf="@+id/video_frame"
        android:layout_alignTop="@+id/video_frame"
        android:layout_alignBottom="@+id/video_frame">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                android:textSize="@dimen/sm_32"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:ellipsize="marquee"
                android:id="@+id/tv_details_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/sm_220"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"/>
            <TextView
                android:textSize="@dimen/sm_22"
                android:textColor="#aaaaaa"
                android:id="@+id/tv_details_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sm_15"/>
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="#2196f3"
                android:id="@+id/tv_details_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sm_15"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/sm_18"
            android:textColor="#aaaaaa"
            android:ellipsize="end"
            android:id="@+id/tv_details_director"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_15"
            android:maxLines="1"/>
        <TextView
            android:textSize="@dimen/sm_18"
            android:textColor="#aaaaaa"
            android:ellipsize="end"
            android:id="@+id/tv_details_actors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_10"
            android:maxLines="1"/>
        <TextView
            android:textSize="@dimen/sm_18"
            android:textColor="#aaaaaa"
            android:ellipsize="end"
            android:id="@+id/tv_details_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_10"
            android:maxLines="1"/>
        <TextView
            android:textSize="@dimen/sm_18"
            android:textColor="#aaaaaa"
            android:id="@+id/tv_details_area"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_10"/>
        <TextView
            android:textSize="@dimen/sm_16"
            android:textColor="#888888"
            android:ellipsize="end"
            android:id="@+id/tv_details_intro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_10"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.2"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sm_10">
            <Button
                android:textSize="@dimen/sm_20"
                android:textColor="@android:color/white"
                android:id="@+id/btn_fullscreen"
                android:background="@drawable/selector_play_button"
                android:paddingLeft="@dimen/sm_15"
                android:paddingRight="@dimen/sm_25"
                android:focusable="true"
                android:nextFocusLeft="@+id/video_frame"
                android:nextFocusUp="@+id/video_frame"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sm_45"
                android:text="全屏"
                android:drawablePadding="@dimen/sm_8"/>
            <Button
                android:textSize="@dimen/sm_20"
                android:textColor="@android:color/white"
                android:id="@+id/btn_favorite"
                android:background="@drawable/bg_episode_button"
                android:paddingLeft="@dimen/sm_15"
                android:paddingRight="@dimen/sm_25"
                android:focusable="true"
                android:nextFocusUp="@+id/video_frame"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sm_45"
                android:layout_marginLeft="@dimen/sm_15"
                android:text="收藏"
                android:drawablePadding="@dimen/sm_8"/>
            <Button
                android:textSize="@dimen/sm_20"
                android:textColor="@android:color/white"
                android:id="@+id/btn_source"
                android:background="@drawable/bg_episode_button"
                android:paddingLeft="@dimen/sm_15"
                android:paddingRight="@dimen/sm_25"
                android:focusable="true"
                android:nextFocusUp="@+id/video_frame"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sm_45"
                android:layout_marginLeft="@dimen/sm_15"
                android:text="播放源"
                android:drawablePadding="@dimen/sm_8"/>
            <Button
                android:textSize="@dimen/sm_20"
                android:textColor="@android:color/white"
                android:id="@+id/btn_player_core"
                android:background="@drawable/bg_episode_button"
                android:paddingLeft="@dimen/sm_15"
                android:paddingRight="@dimen/sm_25"
                android:focusable="true"
                android:nextFocusUp="@+id/video_frame"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sm_45"
                android:layout_marginLeft="@dimen/sm_15"
                android:text="IJK"
                android:drawablePadding="@dimen/sm_8"/>
        </LinearLayout>
    </LinearLayout>
    <ScrollView
        android:id="@+id/content_scroll"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/sm_10"
        android:fillViewport="true"
        android:layout_below="@+id/video_frame">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_layer"
            android:paddingLeft="@dimen/sm_40"
            android:paddingRight="@dimen/sm_40"
            android:paddingBottom="@dimen/sm_30"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/episode_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="@android:color/white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剧集列表"/>
                    <TextView
                        android:textSize="@dimen/sm_20"
                        android:textColor="#888888"
                        android:id="@+id/tv_episode_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sm_20"/>
                    <TextView
                        android:textSize="@dimen/sm_18"
                        android:textColor="#2196f3"
                        android:id="@+id/tv_episode_order"
                        android:background="@drawable/bg_episode_button"
                        android:paddingLeft="@dimen/sm_18"
                        android:paddingTop="@dimen/sm_8"
                        android:paddingRight="@dimen/sm_18"
                        android:paddingBottom="@dimen/sm_8"
                        android:focusable="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sm_20"
                        android:text="剧集正序"/>
                    <HorizontalScrollView
                        android:visibility="gone"
                        android:scrollbars="none"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sm_20"
                        android:layout_weight="1">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:id="@+id/page_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </HorizontalScrollView>
                </LinearLayout>
                <HorizontalScrollView
                    android:id="@+id/source_tab_scroll"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_10">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/source_tab_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/episode_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_10"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_details_ad"
                android:focusable="false"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_15"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_15">
                <TextView
                    android:textSize="@dimen/sm_24"
                    android:textColor="@android:color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="相关推荐"/>
                <HorizontalScrollView
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_10">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/recommend_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <FrameLayout
        android:id="@+id/source_panel"
        android:background="#80000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_gravity="end"
            android:orientation="vertical"
            android:background="#222222"
            android:padding="@dimen/sm_16"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/sm_250"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/sm_18"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择播放源"/>
            <ScrollView
                android:focusable="false"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/sm_12"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/source_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/core_panel"
        android:background="#80000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_gravity="end"
            android:orientation="vertical"
            android:background="#222222"
            android:padding="@dimen/sm_16"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/sm_250"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/sm_18"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择播放内核"/>
            <ScrollView
                android:focusable="false"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/sm_12"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/core_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
