<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wellco"
    android:background="#fafafa"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="25sp"
        android:textColor="#bf0e49"
        android:gravity="center"
        android:id="@+id/textViewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="神马视频 APP 用户协议"
        android:layout_below="@+id/imageView"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#171616"
        android:id="@+id/textViewDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:text="欢迎您使用神马视频 APP！在使用本 APP 之前，请您仔细阅读本用户协议（以下简称 “本协议”）。本协议包含了您使用本 APP 时的权利和义务，以及我们的责任和声明。您使用本 APP 即视为您已阅读、理解并同意接受本协议的约束。"
        android:layout_below="@+id/textViewTitle"/>
    <TextView
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#0730c7"
        android:id="@+id/textViewDetails"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:text="详细点击这里"
        android:layout_below="@+id/textViewDescription"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_below="@+id/textViewDetails"
        android:layout_centerHorizontal="true">
        <Button
            android:textColor="#fff"
            android:id="@+id/buttonDisagree"
            android:background="@drawable/rounded_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:layout_marginRight="20dp"
            android:text="不同意"
            android:onClick="unegree"/>
        <Button
            android:textColor="#fff"
            android:id="@+id/buttonAgree"
            android:background="@drawable/rounded_button"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:layout_marginLeft="20dp"
            android:text="同   意"
            android:onClick="agree"/>
    </LinearLayout>
</RelativeLayout>
