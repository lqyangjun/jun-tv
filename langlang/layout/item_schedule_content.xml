<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/item_content_card"
    android:background="@drawable/selector_transparent_bg"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="afterDescendants"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">
    <FrameLayout
        android:clipChildren="false"
        android:clipToPadding="false"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="@dimen/sm_160"
        android:layout_height="@dimen/sm_224">
        <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
            android:id="@+id/video_poster"
            android:layout_width="@dimen/sm_160"
            android:layout_height="@dimen/sm_224"
            android:src="@drawable/default_film_img"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#ffffd700"
            android:layout_gravity="top|left"
            android:id="@+id/video_vip_badge"
            android:background="@drawable/shape_svip_bg"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_marginTop="6dp"
            android:text="SVIP"/>
        <TextView
            android:textSize="@dimen/sm_20"
            android:textStyle="bold"
            android:textColor="@color/Score"
            android:layout_gravity="right"
            android:id="@+id/video_item_Score"
            android:background="@drawable/score_bg_rounded"
            android:paddingLeft="@dimen/sm_5"
            android:paddingTop="@dimen/sm_2"
            android:paddingRight="@dimen/sm_5"
            android:paddingBottom="@dimen/sm_2"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""/>
        <TextView
            android:textSize="@dimen/sm_20"
            android:textColor="@color/detail_point"
            android:gravity="center_horizontal"
            android:layout_gravity="bottom|center_horizontal"
            android:id="@+id/video_state"
            android:background="@drawable/video_textbg_selector_rounded"
            android:layout_width="@dimen/sm_160"
            android:layout_height="@dimen/sm_30"
            style="@style/marqueeText"/>
        <ImageView
            android:id="@+id/video_focus_border"
            android:background="@drawable/selector_card_focus"
            android:duplicateParentState="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <TextView
        android:textSize="@dimen/sm_22"
        android:textColor="@drawable/video_textcolor_selector"
        android:id="@+id/video_name"
        android:layout_width="@dimen/sm_160"
        android:layout_height="@dimen/sm_50"
        android:layout_marginTop="@dimen/sm_6"
        style="@style/marqueeText"/>
</LinearLayout>
