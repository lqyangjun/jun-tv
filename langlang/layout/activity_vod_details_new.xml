<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_deep_blue_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/main_scroll_view"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="@dimen/sm_60"
            android:paddingTop="@dimen/sm_40"
            android:paddingRight="@dimen/sm_60"
            android:paddingBottom="@dimen/sm_40"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:id="@+id/player_container"
                    android:background="#000000"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/sm_280"
                    android:layout_weight="1">
                    <tv.danmaku.ijk.media.example.widget.media.IjkVideoView
                        android:id="@+id/mini_video_view"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <FrameLayout
                        android:id="@+id/loading_container"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.shenma.tvlauncher.view.PlayerProgressBar
                            android:layout_gravity="center"
                            android:id="@+id/mini_progress_bar"
                            android:layout_width="@dimen/sm_80"
                            android:layout_height="@dimen/sm_80"
                            android:indeterminate="false"
                            android:indeterminateDrawable="@drawable/loadingprogress"/>
                    </FrameLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:id="@+id/trial_end_container"
                        android:background="#cc000000"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <TextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/white"
                            android:id="@+id/tv_trial_msg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="视频试看结束，请前往积分中心兑换权益"/>
                        <Button
                            android:textSize="@dimen/sm_22"
                            android:textColor="@color/white"
                            android:id="@+id/btn_exchange"
                            android:background="@drawable/bg_player_button"
                            android:paddingLeft="@dimen/sm_30"
                            android:paddingRight="@dimen/sm_30"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/sm_50"
                            android:layout_marginTop="@dimen/sm_20"
                            android:text="积分兑换"/>
                    </LinearLayout>
                    <TableLayout
                        android:id="@+id/hubview"
                        android:visibility="invisible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </FrameLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sm_40"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="@dimen/sm_36"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:ellipsize="end"
                        android:id="@+id/tv_details_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"/>
                    <TextView
                        android:textSize="@dimen/sm_22"
                        android:textColor="#888888"
                        android:id="@+id/tv_details_area_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sm_10"/>
                    <TextView
                        android:textSize="@dimen/sm_20"
                        android:textColor="@color/white"
                        android:ellipsize="end"
                        android:id="@+id/tv_details_actors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sm_15"
                        android:maxLines="2"/>
                    <TextView
                        android:textSize="@dimen/sm_18"
                        android:textColor="#aaaaaa"
                        android:ellipsize="end"
                        android:id="@+id/tv_details_intro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sm_15"
                        android:maxLines="3"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sm_25">
                        <Button
                            android:textSize="@dimen/sm_20"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/btn_fullscreen"
                            android:background="@drawable/bg_player_button"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:nextFocusRight="@+id/btn_favorite"
                            android:nextFocusDown="@+id/tv_episode_order"
                            android:layout_width="@dimen/sm_120"
                            android:layout_height="@dimen/sm_50"
                            android:text="全屏"
                            android:drawableLeft="@drawable/ic_fullscreen"
                            android:drawablePadding="@dimen/sm_8"/>
                        <Button
                            android:textSize="@dimen/sm_20"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/btn_favorite"
                            android:background="@drawable/bg_player_button"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:nextFocusLeft="@+id/btn_fullscreen"
                            android:nextFocusRight="@+id/btn_source"
                            android:nextFocusDown="@+id/tv_episode_order"
                            android:layout_width="@dimen/sm_120"
                            android:layout_height="@dimen/sm_50"
                            android:layout_marginLeft="@dimen/sm_15"
                            android:text="收藏"
                            android:drawableLeft="@drawable/ic_favorite"
                            android:drawablePadding="@dimen/sm_8"/>
                        <Button
                            android:textSize="@dimen/sm_20"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/btn_source"
                            android:background="@drawable/bg_player_button"
                            android:paddingLeft="@dimen/sm_15"
                            android:paddingRight="@dimen/sm_15"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:nextFocusLeft="@+id/btn_favorite"
                            android:nextFocusRight="@+id/btn_player_core"
                            android:nextFocusDown="@+id/tv_episode_order"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/sm_50"
                            android:layout_marginLeft="@dimen/sm_15"
                            android:text="播放源"
                            android:drawableRight="@drawable/ic_arrow_right"
                            android:drawablePadding="@dimen/sm_8"/>
                        <Button
                            android:textSize="@dimen/sm_20"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/btn_player_core"
                            android:background="@drawable/bg_player_button"
                            android:paddingLeft="@dimen/sm_15"
                            android:paddingRight="@dimen/sm_15"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:nextFocusLeft="@+id/btn_source"
                            android:nextFocusDown="@+id/tv_episode_order"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/sm_50"
                            android:layout_marginLeft="@dimen/sm_15"
                            android:text="IJK"
                            android:drawableRight="@drawable/ic_arrow_right"
                            android:drawablePadding="@dimen/sm_8"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_30">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/sm_26"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剧集列表"/>
                    <View
                        android:background="#555555"
                        android:layout_width="1dp"
                        android:layout_height="@dimen/sm_20"
                        android:layout_marginLeft="@dimen/sm_15"
                        android:layout_marginRight="@dimen/sm_15"/>
                    <TextView
                        android:textSize="@dimen/sm_22"
                        android:textColor="#888888"
                        android:id="@+id/tv_episode_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0集全"/>
                    <View
                        android:background="#555555"
                        android:layout_width="1dp"
                        android:layout_height="@dimen/sm_20"
                        android:layout_marginLeft="@dimen/sm_15"
                        android:layout_marginRight="@dimen/sm_15"/>
                    <TextView
                        android:textSize="@dimen/sm_22"
                        android:textColor="#888888"
                        android:id="@+id/tv_episode_order"
                        android:background="@drawable/bg_player_button"
                        android:paddingLeft="@dimen/sm_15"
                        android:paddingTop="@dimen/sm_5"
                        android:paddingRight="@dimen/sm_15"
                        android:paddingBottom="@dimen/sm_5"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:nextFocusUp="@+id/btn_fullscreen"
                        android:clickable="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剧集正序"/>
                </LinearLayout>
                <HorizontalScrollView
                    android:id="@+id/episode_scroll_view"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_20">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/episode_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
                <HorizontalScrollView
                    android:id="@+id/page_scroll_view"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_15">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/page_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/recommend_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_30">
                <TextView
                    android:textSize="@dimen/sm_26"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="相关推荐"/>
                <HorizontalScrollView
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sm_20">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/recommend_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <FrameLayout
        android:layout_gravity="end"
        android:id="@+id/source_panel"
        android:background="@drawable/bg_side_panel"
        android:visibility="gone"
        android:layout_width="@dimen/sm_350"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/sm_25"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/sm_28"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="播放源"/>
            <ScrollView
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/sm_20"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/source_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
    <FrameLayout
        android:layout_gravity="end"
        android:id="@+id/core_panel"
        android:background="@drawable/bg_side_panel"
        android:visibility="gone"
        android:layout_width="@dimen/sm_350"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/sm_25"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/sm_28"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="播放内核"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/core_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sm_20"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
