<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/media_controler_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <HorizontalScrollView
        android:paddingLeft="@dimen/sm_20"
        android:paddingTop="@dimen/sm_10"
        android:paddingRight="@dimen/sm_20"
        android:paddingBottom="@dimen/sm_5"
        android:focusable="false"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_next_episode"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="下集"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_prev_episode"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="上集"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_episodes"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="选集"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_core"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="EXO"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_decode"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="硬解"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_speed"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="1.00"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_ratio"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="原始"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_intro"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="片头"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_ending"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="片尾"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_danmaku"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="弹幕"/>
            <Button
                android:textSize="@dimen/sm_14"
                android:textColor="@android:color/white"
                android:id="@+id/btn_menu_ctrl"
                android:background="@drawable/bg_episode_button"
                android:focusable="true"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_40"
                android:layout_marginRight="@dimen/sm_10"
                android:text="菜单"/>
        </LinearLayout>
    </HorizontalScrollView>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/sm_20"
        android:paddingRight="@dimen/sm_20"
        android:paddingBottom="@dimen/sm_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/sm_16"
            android:textColor="@android:color/white"
            android:id="@+id/tv_currentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/sm_10"
            android:text="00:00:00"/>
        <SeekBar
            android:id="@+id/seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxHeight="@dimen/sm_10"
            android:progress="0"
            android:secondaryProgress="0"
            android:progressDrawable="@drawable/seekbar_style"
            android:minHeight="@dimen/sm_10"
            android:thumb="@drawable/seekbar_thumb"
            android:thumbOffset="0dp"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/sm_16"
            android:textColor="@android:color/white"
            android:id="@+id/tv_totalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sm_10"
            android:text="00:00:00"/>
    </LinearLayout>
</LinearLayout>
