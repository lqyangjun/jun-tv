<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:clv="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_425"/>
    <RelativeLayout
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@+id/fl_re_0"
            android:background="@drawable/selector_transparent"
            android:layout_width="@dimen/sm_580"
            android:layout_height="@dimen/sm_300"
            android:layout_marginLeft="@dimen/sm_10"
            android:layout_marginTop="@dimen/sm_6"
            android:foreground="@drawable/selector_transparent">
            <ImageView
                android:id="@+id/re_bg_0"
                android:background="@null"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@null"
                android:scaleType="fitXY"/>
            <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
                android:id="@+id/iv_re_0"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/fl_re_0"
                android:scaleType="centerCrop"
                clv:siBorderColor="@color/darkgray"
                clv:siRadius="@dimen/sm_20"/>
            <com.shenma.tvlauncher.view.FullVideoView
                android:id="@+id/vv_re_0"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.shenma.tvlauncher.view.cornerlabelview.CornerLabelView
                android:id="@+id/jb_1"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_100"
                clv:bg_color="@color/red"
                clv:position="3"
                clv:side_length="@dimen/sm_50"
                clv:text="@string/Hot_broadcast"
                clv:text_color="@color/whites"
                clv:text_size="@dimen/sm_25"/>
            <TextView
                android:textSize="@dimen/sm_25"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_re_0"
                android:background="@drawable/text_bgss"
                android:paddingBottom="@dimen/sm_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_64"
                android:layout_marginTop="@dimen/sm_240"
                android:singleLine="true"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_re_1"
            android:background="@drawable/selector_transparent"
            android:layout_width="@dimen/sm_580"
            android:layout_height="@dimen/sm_300"
            android:layout_marginLeft="@dimen/sm_10"
            android:layout_marginTop="@dimen/sm_6"
            android:foreground="@drawable/selector_transparent"
            android:layout_toRightOf="@+id/fl_re_0">
            <ImageView
                android:id="@+id/re_bg_1"
                android:background="@null"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@null"
                android:scaleType="fitXY"/>
            <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
                android:id="@+id/iv_re_1"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/fl_re_0"
                android:scaleType="centerCrop"
                clv:siBorderColor="@color/darkgray"
                clv:siRadius="@dimen/sm_20"/>
            <com.shenma.tvlauncher.view.FullVideoView
                android:id="@+id/vv_re_1"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.shenma.tvlauncher.view.cornerlabelview.CornerLabelView
                android:id="@+id/jb_2"
                android:layout_width="@dimen/sm_100"
                android:layout_height="@dimen/sm_100"
                clv:bg_color="@color/detail_point"
                clv:position="3"
                clv:side_length="@dimen/sm_50"
                clv:text="@string/recommends"
                clv:text_color="@color/whites"
                clv:text_size="@dimen/sm_25"/>
            <TextView
                android:textSize="@dimen/sm_25"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_re_1"
                android:background="@drawable/text_bgss"
                android:paddingBottom="@dimen/sm_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_64"
                android:layout_marginTop="@dimen/sm_240"
                android:singleLine="true"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_re_2"
            android:background="@drawable/selector_transparent"
            android:layout_width="@dimen/sm_285"
            android:layout_height="@dimen/sm_160"
            android:layout_marginLeft="@dimen/sm_10"
            android:layout_marginTop="@dimen/sm_15"
            android:foreground="@drawable/selector_transparent"
            android:layout_below="@+id/fl_re_0">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/btn_history_new"
                    android:background="@drawable/selector_btn_top"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <ImageView
                        android:layout_width="@dimen/sm_40"
                        android:layout_height="@dimen/sm_40"
                        android:src="@drawable/lisjl"/>
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="@color/white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sm_10"
                        android:text="播放历史"/>
                </LinearLayout>
                <View
                    android:background="#20ffffff"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/btn_collect_new"
                    android:background="@drawable/selector_btn_bottom"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <ImageView
                        android:layout_width="@dimen/sm_40"
                        android:layout_height="@dimen/sm_40"
                        android:src="@drawable/pbq"/>
                    <TextView
                        android:textSize="@dimen/sm_24"
                        android:textColor="@color/white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sm_10"
                        android:text="排表期"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_re_3"
            android:background="@drawable/selector_transparent"
            android:layout_width="@dimen/sm_285"
            android:layout_height="@dimen/sm_160"
            android:layout_marginLeft="@dimen/sm_10"
            android:layout_marginTop="@dimen/sm_15"
            android:foreground="@drawable/selector_transparent"
            android:layout_toRightOf="@+id/fl_re_2"
            android:layout_below="@+id/fl_re_0">
            <ImageView
                android:id="@+id/re_bg_3"
                android:background="@null"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@null"
                android:scaleType="fitXY"/>
            <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
                android:id="@+id/iv_re_3"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/fl_re_0"
                android:scaleType="centerCrop"
                clv:siBorderColor="@color/darkgray"
                clv:siRadius="@dimen/sm_20"/>
            <com.shenma.tvlauncher.view.FullVideoView
                android:id="@+id/vv_re_3"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.shenma.tvlauncher.view.cornerlabelview.CornerLabelView
                android:id="@+id/jb_4"
                android:layout_width="@dimen/sm_80"
                android:layout_height="@dimen/sm_80"
                clv:bg_color="@color/player_back"
                clv:position="3"
                clv:side_length="@dimen/sm_40"
                clv:text="@string/recommends"
                clv:text_color="@color/whites"
                clv:text_size="@dimen/sm_20"/>
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_re_3"
                android:background="@drawable/text_bgss"
                android:paddingBottom="@dimen/sm_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_40"
                android:layout_marginTop="@dimen/sm_125"
                android:singleLine="true"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_re_4"
            android:background="@drawable/selector_transparent"
            android:layout_width="@dimen/sm_285"
            android:layout_height="@dimen/sm_160"
            android:layout_marginLeft="@dimen/sm_10"
            android:layout_marginTop="@dimen/sm_15"
            android:foreground="@drawable/selector_transparent"
            android:layout_toRightOf="@+id/fl_re_3"
            android:layout_below="@+id/fl_re_1">
            <ImageView
                android:id="@+id/re_bg_4"
                android:background="@null"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@null"
                android:scaleType="fitXY"/>
            <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
                android:id="@+id/iv_re_4"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/fl_re_0"
                android:scaleType="centerCrop"
                clv:siBorderColor="@color/darkgray"
                clv:siRadius="@dimen/sm_20"/>
            <com.shenma.tvlauncher.view.FullVideoView
                android:id="@+id/vv_re_4"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.shenma.tvlauncher.view.cornerlabelview.CornerLabelView
                android:id="@+id/jb_5"
                android:layout_width="@dimen/sm_80"
                android:layout_height="@dimen/sm_80"
                clv:bg_color="@color/blue_user"
                clv:position="3"
                clv:side_length="@dimen/sm_40"
                clv:text="@string/recommends"
                clv:text_color="@color/whites"
                clv:text_size="@dimen/sm_20"/>
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_re_4"
                android:background="@drawable/text_bgss"
                android:paddingBottom="@dimen/sm_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_40"
                android:layout_marginTop="@dimen/sm_125"
                android:singleLine="true"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_re_5"
            android:background="@drawable/selector_transparent"
            android:layout_width="@dimen/sm_285"
            android:layout_height="@dimen/sm_160"
            android:layout_marginLeft="@dimen/sm_10"
            android:layout_marginTop="@dimen/sm_15"
            android:foreground="@drawable/selector_transparent"
            android:layout_toRightOf="@+id/fl_re_4"
            android:layout_below="@+id/fl_re_1">
            <ImageView
                android:id="@+id/re_bg_5"
                android:background="@null"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@null"
                android:scaleType="fitXY"/>
            <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView
                android:id="@+id/iv_re_5"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/fl_re_1"
                android:scaleType="centerCrop"
                clv:siBorderColor="@color/darkgray"
                clv:siRadius="@dimen/sm_20"/>
            <com.shenma.tvlauncher.view.FullVideoView
                android:id="@+id/vv_re_5"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.shenma.tvlauncher.view.cornerlabelview.CornerLabelView
                android:id="@+id/jb_6"
                android:layout_width="@dimen/sm_80"
                android:layout_height="@dimen/sm_80"
                clv:bg_color="@color/brown"
                clv:position="3"
                clv:side_length="@dimen/sm_40"
                clv:text="@string/recommends"
                clv:text_color="@color/whites"
                clv:text_size="@dimen/sm_20"/>
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:gravity="bottom|center_horizontal"
                android:id="@+id/tv_re_5"
                android:background="@drawable/text_bgss"
                android:paddingBottom="@dimen/sm_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sm_40"
                android:layout_marginTop="@dimen/sm_125"
                android:singleLine="true"/>
        </FrameLayout>
    </RelativeLayout>
</FrameLayout>
