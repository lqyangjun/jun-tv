<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/top_bar_yangwang"
        android:background="@android:color/transparent"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">
        <ImageView
            android:id="@+id/iv_logo_yangwang"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:src="@drawable/sm_logo"
            android:adjustViewBounds="true"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/btn_user_yangwang"
            android:background="@drawable/bg_top_button_yangwang"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginLeft="20dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="20dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_user_new"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:text="我的"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/btn_setting_yangwang"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_gonggao_yangwang"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="公告："/>
            <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:id="@+id/tv_gonggao_yangwang"
                android:focusable="false"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="6dp"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:layout_weight="1"
                android:marqueeRepeatLimit="marquee_forever"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/btn_clear_cache_yangwang"
            android:background="@drawable/bg_top_button_yangwang"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_clear"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:text="清除缓存"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/iv_net_state_yangwang"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginLeft="10dp"
            android:src="@drawable/wifi"
            android:layout_marginStart="10dp"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/tv_time_yangwang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="12:00"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/rg_video_type_bottoms"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginRight="12dp"
        android:layout_below="@+id/top_bar_yangwang"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp">
        <HorizontalScrollView
            android:scrollbars="none"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioGroup
                android:orientation="horizontal"
                android:id="@+id/rg_video_type_bottom"
                android:clipChildren="true"
                android:clipToPadding="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/content_area_yangwang"
        android:padding="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="6dp"
        android:layout_below="@+id/rg_video_type_bottoms">
        <LinearLayout
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginRight="10dp"
            android:layout_weight="25"
            android:layout_marginEnd="10dp">
            <FrameLayout
                android:id="@+id/card_1_yangwang"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:foreground="@drawable/selector_focus_yangwang"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/iv_card_1_yangwang"
                    android:background="#333333"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_gravity="start|bottom"
                    android:id="@+id/tv_card_1_title_yangwang"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="10dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:layout_marginStart="10dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    android:layout_gravity="start|bottom"
                    android:id="@+id/tv_card_1_subtitle_yangwang"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/card_3_yangwang"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:foreground="@drawable/selector_focus_yangwang"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/iv_card_3_yangwang"
                    android:background="#333333"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_gravity="start|bottom"
                    android:id="@+id/tv_card_3_title_yangwang"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="10dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:layout_marginStart="10dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    android:layout_gravity="start|bottom"
                    android:id="@+id/tv_card_3_subtitle_yangwang"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/card_2_yangwang"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:foreground="@drawable/selector_focus_yangwang"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/iv_card_2_yangwang"
                    android:background="#333333"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_gravity="start|bottom"
                    android:id="@+id/tv_card_2_title_yangwang"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="10dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:layout_marginStart="10dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    android:layout_gravity="start|bottom"
                    android:id="@+id/tv_card_2_subtitle_yangwang"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"/>
            </FrameLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="75">
            <LinearLayout
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="6"
                android:layout_marginEnd="10dp">
                <FrameLayout
                    android:id="@+id/card_live_yangwang"
                    android:background="#1a1a2e"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="8dp"
                    android:foreground="@drawable/selector_focus_yangwang"
                    android:layout_weight="3">
                    <ImageView
                        android:id="@+id/iv_live_placeholder_yangwang"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>
                    <tv.danmaku.ijk.media.example.widget.media.IjkVideoView
                        android:id="@+id/vv_live_preview_yangwang"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ffffff"
                        android:id="@+id/tv_live_tag_yangwang"
                        android:background="#e53935"
                        android:paddingLeft="8dp"
                        android:paddingTop="3dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="3dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:text="点击放大"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                    <LinearLayout
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:background="@drawable/bg_gradient_bottom_yangwang"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/tv_live_channel_yangwang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CCTV-1 综合频道"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"/>
                        <TextView
                            android:textSize="14sp"
                            android:textColor="#b3ffffff"
                            android:id="@+id/tv_live_program_yangwang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="正在播放：新闻30分"/>
                    </LinearLayout>
                </FrameLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/bottom_bar_yangwang"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="1.8"
                android:layout_marginEnd="10dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.3">
                    <FrameLayout
                        android:id="@+id/btn_search_yangwang"
                        android:background="@drawable/selector_func_user_starry"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="6dp"
                        android:foreground="@drawable/selector_focus_yangwang"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/search"/>
                            <TextView
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#ffffff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:text="搜索"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                    <FrameLayout
                        android:id="@+id/btn_history_yangwang"
                        android:background="@drawable/selector_func_search_starry"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="6dp"
                        android:foreground="@drawable/selector_focus_yangwang"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_history_new"/>
                            <TextView
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#ffffff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:text="观看历史"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                    <FrameLayout
                        android:id="@+id/btn_favorite_yangwang"
                        android:background="@drawable/selector_func_favorite_starry"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="6dp"
                        android:foreground="@drawable/selector_focus_yangwang"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_control_keep_ok"/>
                            <TextView
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#ffffff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:text="我的收藏"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                    <FrameLayout
                        android:id="@+id/btn_schedule_yangwang"
                        android:background="@drawable/selector_func_clear_starry"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="6dp"
                        android:foreground="@drawable/selector_focus_yangwang"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_schedule_item"/>
                            <TextView
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#ffffff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:text="排期表"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                    <FrameLayout
                        android:id="@+id/btn_setting_center_yangwang"
                        android:background="@drawable/selector_func_setting_starry"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:foreground="@drawable/selector_focus_yangwang"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/setting"/>
                            <TextView
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#ffffff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:text="设置"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.5"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout
        android:padding="15dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/rg_video_type_bottoms">
        <LinearLayout
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3"/>
            <LinearLayout
                android:orientation="horizontal"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="1dp"
                android:layout_weight="0.9">
                <FrameLayout
                    android:id="@+id/card_4_yangwang"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="8dp"
                    android:foreground="@drawable/selector_focus_yangwang"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">
                    <ImageView
                        android:id="@+id/iv_card_4_yangwang"
                        android:background="#333333"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"/>
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:layout_gravity="start|bottom"
                        android:id="@+id/tv_card_4_title_yangwang"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginBottom="10dp"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="3"
                        android:layout_marginStart="10dp"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ffffff"
                        android:layout_gravity="start|bottom"
                        android:id="@+id/tv_card_4_subtitle_yangwang"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"/>
                </FrameLayout>
                <FrameLayout
                    android:id="@+id/card_5_yangwang"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="8dp"
                    android:foreground="@drawable/selector_focus_yangwang"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">
                    <ImageView
                        android:id="@+id/iv_card_5_yangwang"
                        android:background="#333333"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"/>
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:layout_gravity="start|bottom"
                        android:id="@+id/tv_card_5_title_yangwang"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginBottom="10dp"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="3"
                        android:layout_marginStart="10dp"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ffffff"
                        android:layout_gravity="start|bottom"
                        android:id="@+id/tv_card_5_subtitle_yangwang"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"/>
                </FrameLayout>
                <FrameLayout
                    android:id="@+id/card_6_yangwang"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="8dp"
                    android:foreground="@drawable/selector_focus_yangwang"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">
                    <ImageView
                        android:id="@+id/iv_card_6_yangwang"
                        android:background="#333333"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"/>
                    <TextView
