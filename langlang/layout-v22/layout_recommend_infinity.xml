<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/top_bar_infinity"
        android:paddingTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:paddingStart="26dp"
        android:paddingEnd="26dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/btn_search_infinity"
                android:background="@drawable/selector_top_button_focus"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_search_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/sosuo"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_search_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="搜索"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/btn_history_infinity"
                android:background="@drawable/selector_top_button_focus"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp">
                <ImageView
                    android:id="@+id/iv_history_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/lisjl"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_history_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="历史"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/btn_play_setting_infinity"
                android:background="@drawable/selector_top_button_focus"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp">
                <ImageView
                    android:id="@+id/iv_setting_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/set"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_setting_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设置"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/btn_user_infinity"
                android:background="@drawable/selector_top_button_focus"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp">
                <ImageView
                    android:id="@+id/iv_user_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/wode"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_user_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/gonggao_layout_infinity"
                android:background="@drawable/bg_gonggao_marquee"
                android:padding="6dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minWidth="290dp"
                android:layout_weight="3"
                android:layout_marginStart="5dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="#ffc107"
                    android:id="@+id/tv_gonggao_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="公告："
                    android:singleLine="true"
                    android:layout_marginEnd="4dp"/>
                <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                    android:textSize="16sp"
                    android:textColor="#b3ffffff"
                    android:ellipsize="marquee"
                    android:id="@+id/tv_gonggao_infinity"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minWidth="260dp"
                    android:text=""
                    android:scrollHorizontally="true"
                    android:singleLine="true"
                    android:layout_weight="1"
                    android:marqueeRepeatLimit="marquee_forever"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/func_clear_starry"
                android:background="@drawable/selector_clear_cache_round_blue"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@+id/func_setting_starry"
                android:nextFocusUp="@+id/hero_container_starry"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="0dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">
                <ImageView
                    android:id="@+id/func_clear_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/qc"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:text="清除缓存"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/top_info_infinity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp">
            <ImageView
                android:id="@+id/iv_net_state_infinity"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/wifi"
                android:layout_marginEnd="15dp"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/tv_time_infinity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/info_container_infinity"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/progressLayout"
        android:layout_below="@+id/top_bar_infinity"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">
        <HorizontalScrollView
            android:id="@+id/category_scroll_infinity"
            android:paddingTop="5dp"
            android:focusable="false"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/category_container_infinity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
        <ImageView
            android:id="@+id/logo_infinity"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <LinearLayout
            android:id="@+id/top_nav_infinity"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/bottom_info_container"
            android:paddingTop="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/category_scroll_infinity">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:id="@+id/tv_title_infinity"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffc107"
                    android:id="@+id/tv_rating_infinity"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="#b3ffffff"
                android:id="@+id/tv_info_infinity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#b3ffffff"
                android:ellipsize="end"
                android:id="@+id/tv_desc_infinity"
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:maxLines="2"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/btn_container_infinity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/btn_play_now_infinity"
                    android:background="@drawable/selector_play_button"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_play_arrow_white"/>
                    <TextView
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="立即播放"
                        android:layout_marginStart="5dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/btn_collect_infinity"
                    android:background="@drawable/selector_collect_button"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="10dp">
                    <ImageView
                        android:id="@+id/iv_collect_icon_infinity"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_heart_white"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#ffffff"
                        android:id="@+id/tv_collect_text_infinity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="收藏"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/progressLayout"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_alignParentBottom="true">
        <HorizontalScrollView
            android:id="@+id/hsv_recommend_infinity"
            android:background="@android:color/transparent"
            android:paddingTop="12dp"
            android:paddingBottom="24dp"
            android:focusable="false"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="26dp"
            android:paddingEnd="26dp">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_recommend_container"
                android:background="@android:color/transparent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"/>
        </HorizontalScrollView>
    </LinearLayout>
    <TextView
        android:id="@+id/tv_year_infinity"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
    <TextView
        android:id="@+id/tv_type_infinity"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
    <Button
        android:id="@+id/btn_play_infinity"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
</RelativeLayout>
