<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/video_details_bg"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/schedule_sidebar"
        android:background="#0dffffff"
        android:paddingTop="60dp"
        android:layout_width="260dp"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:paddingLeft="40dp"
            android:paddingBottom="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <View
                android:background="#00e5ff"
                android:layout_width="8dp"
                android:layout_height="24dp"
                android:layout_marginRight="12dp"/>
            <TextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#00e5ff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="每周排期"
                android:letterSpacing="0.1"/>
        </LinearLayout>
        <android.support.v7.widget.RecyclerView
            android:id="@+id/rv_schedule_days"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:padding="40dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toRightOf="@+id/schedule_sidebar">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <TextView
                android:textSize="32sp"
                android:textColor="#ffffff"
                android:id="@+id/tv_schedule_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周一推荐"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#cccccc"
                android:id="@+id/tv_schedule_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="今日精选佳片，精彩不容错过"/>
        </LinearLayout>
        <android.support.v7.widget.RecyclerView
            android:id="@+id/rv_schedule_content"
            android:padding="10dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginRight="40dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true">
        <TextView
            android:textSize="16sp"
            android:textColor="#e6ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:text="[OK] 确认"/>
        <TextView
            android:textSize="16sp"
            android:textColor="#e6ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:text="[← →] 切换"/>
        <TextView
            android:textSize="16sp"
            android:textColor="#e6ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[BACK] 返回"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/pb_loading"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
</RelativeLayout>
