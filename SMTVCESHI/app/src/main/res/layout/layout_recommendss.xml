            <com.shenma.tvlauncher.view.shapeimageview.RoundedImageView

                clv:siBorderColor="@color/darkgray"
                android:id="@+id/iv_re_8"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/fl_re_1"
                android:scaleType="centerCrop"/>
            <com.shenma.tvlauncher.view.cornerlabelview.CornerLabelView
                android:id="@+id/jb_9"
                android:layout_width="@dimen/sm_80"
                android:layout_height="@dimen/sm_80"
                clv:bg_color="@color/brown"
                clv:position="left_top"
                clv:side_length="@dimen/sm_40"
                clv:text="@string/recommends"
                android:visibility="gone"
                clv:text_color="@color/whites"
                clv:text_size="@dimen/sm_20" />
            <TextView
                android:textSize="@dimen/sm_20"
                android:textColor="@color/white"
                android:gravity="bottom|center_vertical"
                android:id="@+id/tv_re_8"
