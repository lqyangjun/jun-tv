<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeActivity">

    <FrameLayout
        android:id="@+id/fl_main"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" >

        <RelativeLayout
            android:id="@+id/rl_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" >
            <!--标题-->
            <LinearLayout
                android:id="@+id/mains"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/sm_90">
                <!--应用logo-->
                <ImageView
                    android:id="@+id/logo"
                    android:layout_width="@dimen/sm_152"
                    android:layout_height="@dimen/sm_45"
                    android:src="@drawable/sm_logo" />
                <RelativeLayout
                    android:id="@+id/iv_jilu"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/rb_bm_tvplay"
                    android:layout_width="@dimen/sm_45"
                    android:layout_height="@dimen/sm_45"
                    android:layout_marginLeft="@dimen/sm_10"
                    android:layout_marginRight="@dimen/sm_2"
                    android:background="@mipmap/jilu"
                    android:visibility="gone"
                    android:scaleType="fitXY"/>
                <ImageView
                    android:id="@+id/home_top_record"
                    android:focusable="true"
                    android:nextFocusRight="@+id/rb_bm_tvplay"
                    android:nextFocusDown="@+id/rb_bm_tvplay"
                    android:layout_width="@dimen/sm_40"
                    android:layout_height="@dimen/sm_40"
                    android:layout_marginLeft="@dimen/sm_11"
                    android:layout_marginRight="@dimen/sm_1"
                    style="@style/home_bottom_LinearLayout2"
                    android:src="@mipmap/jilu"
                    android:scaleType="fitXY"
                    android:layout_toRightOf="@+id/home_top_search"/>
                <LinearLayout
                    android:id="@+id/home_user"
                    android:tag="dianxin"
                    android:layout_marginLeft="@dimen/sm_30"
                    style="@style/home_bottom_LinearLayout2">
                    <ImageView
                        android:layout_width="@dimen/sm_38"
                        android:layout_height="@dimen/sm_38"
                        android:layout_marginRight="@dimen/sm_1"
                        style="@style/home_bottom_LinearLayout2"
                        android:src="@mipmap/wode" />
                </LinearLayout>
                <ImageView
                    android:layout_marginLeft="10dp"
                    android:id="@+id/iv_persion"
                    android:layout_width="@dimen/sm_38"
                    android:layout_height="@dimen/sm_338"
                    android:focusable="true"
                    android:visibility="gone"
                    android:layout_marginRight="@dimen/sm_20"
                    />
                <ImageView
                    android:id="@+id/home_top_search"
                    android:layout_width="@dimen/sm_38"
                    android:layout_height="@dimen/sm_38"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="20dp"
                    android:focusable="true"
                    android:nextFocusRight="@+id/rb_bm_tvplay"
                    android:nextFocusDown="@+id/rb_bm_tvplay"
                    android:scaleType="fitXY"
                    style="@style/home_bottom_LinearLayout2"
                    android:src="@mipmap/kmss"></ImageView>
                <RelativeLayout
                    android:layout_width="160dp"
                    android:layout_height="30dp"
                    android:visibility="gone"
                    android:background="@mipmap/sousuo">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="请输入关键字"
                        android:textSize="15dp"
                        android:textColor="#ffffff"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="20dp"></TextView>



                </RelativeLayout>


                <!--公告-->
                <LinearLayout
                    android:layout_width="@dimen/sm_540"
                    android:layout_height="@dimen/sm_46">
                    <!--公告-->
                    <LinearLayout
                        android:layout_marginLeft="@dimen/sm_10"
                        android:id="@+id/gonggao_root"
                        android:layout_width="@dimen/sm_540"
                        android:layout_height="@dimen/sm_46"
                        android:background="@drawable/gonggao_root_bg">
                        <ImageView
                            android:layout_width="@dimen/sm_38"
                            android:layout_height="@dimen/sm_38"
                            android:layout_marginLeft="@dimen/sm_5"
                            android:layout_marginTop="@dimen/sm_4"
                            android:layout_marginRight="@dimen/sm_10"
                            android:src="@drawable/gonggao" />
                        <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                            android:textSize="@dimen/sm_28"
                            android:textColor="@color/white"
                            android:ellipsize="marquee"
                            android:id="@+id/gonggao"
                            android:layout_marginTop="@dimen/sm_4"
                            android:layout_width="@dimen/sm_480"
                            android:layout_height="@dimen/sm_38"
                            android:layout_marginRight="@dimen/sm_30"
                            android:text=""
                            android:singleLine="true"
                            android:marqueeRepeatLimit="marquee_forever" />
                    </LinearLayout>
                </LinearLayout>
                <!--网络状态-->
                <ImageView
                    android:layout_marginLeft="@dimen/sm_20"
                    android:id="@+id/iv_net_state"
                    android:layout_width="@dimen/sm_35"
                    android:layout_height="@dimen/sm_35"
                    android:layout_marginRight="@dimen/sm_30"
                    android:src="@drawable/wifi" />
                <!--时间-->
                <LinearLayout
                    android:id="@+id/main"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/sm_76"
                    android:gravity="center_vertical"
                    android:layout_marginLeft="0dp"
                    android:orientation="horizontal" >
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"

                        android:layout_gravity="center_vertical" >
                        <TextView
                            android:id="@+id/tv_main_time"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"
                            android:gravity="center"
                            android:text="@string/def_time"
                            android:textColor="#ffffff"
                            android:textSize="@dimen/sm_26"/>
                        <TextView
                            android:id="@+id/time_colon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"
                            android:text="@string/time_colon"
                            android:textColor="#ffffff"
                            android:textSize="@dimen/sm_26"
                            android:visibility="gone" />
                    </RelativeLayout>

                    <ImageView
                        android:id="@+id/iv_main_line"
                        android:layout_width="@dimen/sm_25"
                        android:layout_height="@dimen/sm_50"
                        android:gravity="center"
                        android:visibility="gone"
                        android:src="@drawable/home_line" />
                    <TextView
                        android:id="@+id/tv_main_date"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:layout_marginLeft="5dp"
                        android:textColor="#ffffff"
                        android:text="@string/def_date"
                        android:textSize="@dimen/sm_24" />

                </LinearLayout>
            </LinearLayout>



            <!--推荐区域可下拉-->
<!--            <ScrollView-->
<!--                android:layout_below="@+id/mains"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="match_parent"-->
<!--                android:fillViewport="true"-->
<!--                android:scrollbars="none">-->
<!--            </ScrollView>-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_marginTop="50dp">
                    <!--推荐选择-->
                    <LinearLayout
                        android:id="@+id/ll_rb"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sm_50"
                        android:layout_below="@id/mains"
                        android:layout_marginTop="@dimen/sm_20"
                        android:orientation="vertical"
                        android:visibility="visible"
                        android:paddingLeft="@dimen/sm_185" >
                        <RadioGroup
                            android:id="@+id/title_group"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" >
                            <RadioButton
                                android:id="@+id/rb_recommend"
                                style="@style/TitleButton"
                                android:layout_width="0.0px"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:button="@null"
                                android:focusable="true"
                                android:gravity="center"
                                android:nextFocusDown="@+id/iv_re_0"
                                android:nextFocusLeft="@+id/rb_settings"
                                android:nextFocusRight="@+id/rb_video_type"
                                android:text="@string/recommend" />

                            <RadioButton
                                android:id="@+id/rb_video_type"
                                style="@style/TitleButton"
                                android:layout_width="0.0px"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:button="@null"
                                android:focusable="true"
                                android:gravity="center"
                                android:nextFocusLeft="@id/rb_recommend"
                                android:nextFocusRight="@+id/rb_settings"
                                android:nextFocusDown="@+id/topic_iv_0"
                                android:text="@string/video_type" />

                            <RadioButton
                                android:id="@+id/rb_settings"
                                style="@style/TitleButton"
                                android:layout_width="0.0px"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:button="@null"
                                android:focusable="true"
                                android:gravity="center"
                                android:nextFocusLeft="@id/rb_video_type"
                                android:nextFocusRight="@id/rb_recommend"
                                android:text="@string/settings" />
                        </RadioGroup>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/title_group">
                            <ImageView
                                android:id="@id/iv_titile"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="@dimen/sm_2"
                                android:src="@drawable/titile_top"
                                android:layout_weight="1.0" />
                            <View
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2.0" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">
                        <!--类目到导航-->
                        <LinearLayout
                            android:id="@+id/rg_video_type_bottoms"
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="@dimen/sm_15"
                            android:layout_marginRight="10dp"
                            android:gravity="center_horizontal">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_horizontal">

                                <ScrollView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scrollbars="none">
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="right">
                                        <RadioGroup
                                            android:id="@+id/rg_video_type_bottom"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:orientation="vertical"
                                            android:paddingBottom="10dp">
                                        </RadioGroup>
                                    </LinearLayout>
                                </ScrollView>

                            </LinearLayout>

                        </LinearLayout>
                        <!--嵌套-->
                        <android.support.v4.view.ViewPager
                            android:id="@+id/pager"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_above="@+id/rg_video_type_bottoms"
                            android:layout_below="@id/ll_rb"

                            android:layout_weight="4" />
                    </LinearLayout>




                </LinearLayout>



            <!--弹窗公告-->
            <RelativeLayout
                android:id="@+id/notice"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/notice_iamge_url"
                    android:layout_width="@dimen/sm_750"
                    android:layout_height="@dimen/sm_500"
                    android:layout_centerInParent="true"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/notice_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignRight="@id/notice_iamge_url"
                    android:layout_alignBottom="@id/notice_iamge_url"
                    android:layout_marginRight="@dimen/sm_10"
                    android:layout_marginBottom="@dimen/sm_10"
                    android:background="@drawable/button_1"
                    android:text="@string/returns"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sm_20"
                    android:visibility="gone" />
            </RelativeLayout>

        </RelativeLayout>
    </FrameLayout>
    <!--应用更新-->
    <TextView
        android:id="@+id/tv_update_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_80"
        android:layout_gravity="center_horizontal"
        android:textColor="@color/detail_point"
        android:textSize="@dimen/sm_18" />
</FrameLayout>
