<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".HomeActivity">

    <FrameLayout
        android:id="@+id/fl_main"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" >

        <RelativeLayout
            android:id="@+id/rl_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" >
            <!--标题栏 - 优化间距和对齐-->
            <LinearLayout
                android:id="@+id/mains"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/sm_100"
                android:paddingLeft="@dimen/sm_50"
                android:paddingRight="@dimen/sm_50"
                android:paddingTop="@dimen/sm_20"
                android:paddingBottom="@dimen/sm_20"
                android:background="@drawable/header_gradient_bg">
                <!--应用logo - 调整尺寸-->
                <ImageView
                    android:id="@+id/logo"
                    android:layout_width="@dimen/sm_180"
                    android:layout_height="@dimen/sm_55"
                    android:scaleType="fitCenter"
                    android:src="@drawable/sm_logo" />
                    
                <!-- 搜索按钮 - 重新排序到logo右侧 -->
                <ImageView
                    android:id="@+id/home_top_search"
                    android:layout_width="@dimen/sm_48"
                    android:layout_height="@dimen/sm_48"
                    android:layout_marginLeft="@dimen/sm_25"
                    android:focusable="true"
                    android:nextFocusRight="@+id/home_top_record"
                    android:nextFocusDown="@+id/rb_recommend"
                    android:scaleType="fitXY"
                    android:padding="@dimen/sm_8"
                    style="@style/home_bottom_LinearLayout2"
                    android:src="@mipmap/kmss"/>
                    
                <!-- 历史记录按钮 - 优化尺寸 -->
                <ImageView
                    android:id="@+id/home_top_record"
                    android:focusable="true"
                    android:nextFocusRight="@+id/home_user"
                    android:nextFocusDown="@+id/rb_recommend"
                    android:layout_width="@dimen/sm_48"
                    android:layout_height="@dimen/sm_48"
                    android:layout_marginLeft="@dimen/sm_15"
                    android:padding="@dimen/sm_8"
                    style="@style/home_bottom_LinearLayout2"
                    android:src="@mipmap/jilu"
                    android:scaleType="fitXY"/>
                    
                <RelativeLayout
                    android:id="@+id/iv_jilu"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/rb_settings"
                    android:layout_width="@dimen/sm_48"
                    android:layout_height="@dimen/sm_48"
                    android:layout_marginLeft="@dimen/sm_15"
                    android:background="@mipmap/jilu"
                    android:visibility="gone"
                    android:scaleType="fitXY"/>
                    
                <!-- 个人中心按钮 - 优化尺寸 -->
                <LinearLayout
                    android:id="@+id/home_user"
                    android:tag="dianxin"
                    android:layout_marginLeft="@dimen/sm_15"
                    android:padding="@dimen/sm_8"
                    style="@style/home_bottom_LinearLayout2">
                    <ImageView
                        android:layout_width="@dimen/sm_48"
                        android:layout_height="@dimen/sm_48"
                        style="@style/home_bottom_LinearLayout2"
                        android:src="@mipmap/wode" />
                </LinearLayout>
                
                <ImageView
                    android:layout_marginLeft="@dimen/sm_15"
                    android:id="@+id/iv_persion"
                    android:layout_width="@dimen/sm_48"
                    android:layout_height="@dimen/sm_48"
                    android:focusable="true"
                    android:visibility="gone"
                    android:layout_marginRight="@dimen/sm_20"
                    />

                <!-- 公告栏 - 优化样式和间距 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/sm_52"
                    android:layout_marginLeft="@dimen/sm_30"
                    android:layout_marginRight="@dimen/sm_30">
                    <LinearLayout
                        android:id="@+id/gonggao_root"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingLeft="@dimen/sm_15"
                        android:paddingRight="@dimen/sm_15"
                        android:gravity="center_vertical"
                        android:background="@drawable/gonggao_root_bg">
                        <ImageView
                            android:layout_width="@dimen/sm_32"
                            android:layout_height="@dimen/sm_32"
                            android:layout_marginRight="@dimen/sm_12"
                            android:src="@drawable/gonggao" />
                        <com.shenma.tvlauncher.view.AlwaysMarqueeTextView
                            android:textSize="@dimen/sm_24"
                            android:textColor="@color/white"
                            android:ellipsize="marquee"
                            android:id="@+id/gonggao"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:singleLine="true"
                            android:marqueeRepeatLimit="marquee_forever" />
                    </LinearLayout>
                </LinearLayout>

                <!--网络状态图标 - 优化尺寸-->
                <ImageView
                    android:layout_marginLeft="@dimen/sm_20"
                    android:id="@+id/iv_net_state"
                    android:layout_width="@dimen/sm_42"
                    android:layout_height="@dimen/sm_42"
                    android:padding="@dimen/sm_4"
                    android:src="@drawable/wifi" />
                    
                <!--时间显示 - 优化排版-->
                <LinearLayout
                    android:id="@+id/main"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:layout_marginLeft="@dimen/sm_20"
                    android:orientation="horizontal" >
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_vertical" >
                        <TextView
                            android:id="@+id/tv_main_time"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"
                            android:gravity="center"
                            android:text="@string/def_time"
                            android:textColor="#ffffff"
                            android:textSize="@dimen/sm_28"/>
                        <TextView
                            android:id="@+id/time_colon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"
                            android:text="@string/time_colon"
                            android:textColor="#ffffff"
                            android:textSize="@dimen/sm_28"
                            android:visibility="gone" />
                    </RelativeLayout>

                    <ImageView
                        android:id="@+id/iv_main_line"
                        android:layout_width="@dimen/sm_2"
                        android:layout_height="@dimen/sm_30"
                        android:layout_marginLeft="@dimen/sm_12"
                        android:layout_marginRight="@dimen/sm_12"
                        android:background="#40ffffff"
                        android:visibility="visible" />
                        
                    <TextView
                        android:id="@+id/tv_main_date"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:textColor="#ccffffff"
                        android:text="@string/def_date"
                        android:textSize="@dimen/sm_24" />

                </LinearLayout>
                
                <!-- 移除旧的搜索按钮位置 -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone">
                </RelativeLayout>
            </LinearLayout>



            <!--内容区域 - 优化布局-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_below="@+id/mains"
                    android:layout_marginTop="@dimen/sm_10">
                    <!--分类导航 - 优化样式-->
                    <LinearLayout
                        android:id="@+id/ll_rb"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sm_70"
                        android:layout_marginTop="@dimen/sm_20"
                        android:layout_marginBottom="@dimen/sm_10"
                        android:orientation="vertical"
                        android:visibility="visible"
                        android:paddingLeft="@dimen/sm_185"
                        android:paddingRight="@dimen/sm_50" >
                        <RadioGroup
                            android:id="@+id/title_group"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" >
                            <RadioButton
                                android:id="@+id/rb_recommend"
                                style="@style/TitleButton"
                                android:layout_width="0.0px"
                                android:layout_height="@dimen/sm_56"
                                android:layout_weight="0.5"
                                android:button="@null"
                                android:focusable="true"
                                android:gravity="center"
                                android:nextFocusDown="@+id/iv_re_0"
                                android:nextFocusLeft="@+id/rb_settings"
                                android:nextFocusRight="@+id/rb_video_type"
                                android:nextFocusUp="@+id/home_top_search"
                                android:text="@string/recommend" />

                            <RadioButton
                                android:id="@+id/rb_video_type"
                                style="@style/TitleButton"
                                android:layout_width="0.0px"
                                android:layout_height="@dimen/sm_56"
                                android:layout_weight="0.5"
                                android:button="@null"
                                android:focusable="true"
                                android:gravity="center"
                                android:nextFocusLeft="@id/rb_recommend"
                                android:nextFocusRight="@+id/rb_settings"
                                android:nextFocusDown="@+id/topic_iv_0"
                                android:nextFocusUp="@+id/home_top_search"
                                android:text="@string/video_type" />

                            <RadioButton
                                android:id="@+id/rb_settings"
                                style="@style/TitleButton"
                                android:layout_width="0.0px"
                                android:layout_height="@dimen/sm_56"
                                android:layout_weight="0.5"
                                android:button="@null"
                                android:focusable="true"
                                android:gravity="center"
                                android:nextFocusLeft="@id/rb_video_type"
                                android:nextFocusRight="@id/rb_recommend"
                                android:nextFocusUp="@+id/home_top_search"
                                android:text="@string/settings" />
                        </RadioGroup>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/title_group"
                            android:layout_marginTop="@dimen/sm_8">
                            <ImageView
                                android:id="@id/iv_titile"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/sm_4"
                                android:src="@drawable/titile_top"
                                android:layout_weight="1.0" />
                            <View
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2.0" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/sm_15">
                        <!--侧边分类导航 - 优化宽度和样式-->
                        <LinearLayout
                            android:id="@+id/rg_video_type_bottoms"
                            android:layout_width="@dimen/sm_150"
                            android:layout_height="match_parent"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="@dimen/sm_20"
                            android:layout_marginLeft="@dimen/sm_30"
                            android:layout_marginRight="@dimen/sm_15"
                            android:background="@drawable/side_nav_bg"
                            android:gravity="center_horizontal">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_horizontal"
                                android:paddingTop="@dimen/sm_20"
                                android:paddingBottom="@dimen/sm_20">

                                <ScrollView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scrollbars="none"
                                    android:fadeScrollbars="true"
                                    android:scrollbarSize="0dp">
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center_horizontal">
                                        <RadioGroup
                                            android:id="@+id/rg_video_type_bottom"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="vertical"
                                            android:paddingBottom="@dimen/sm_20">
                                        </RadioGroup>
                                    </LinearLayout>
                                </ScrollView>

                            </LinearLayout>

                        </LinearLayout>
                        <!--主内容区域 - 优化间距-->
                        <android.support.v4.view.ViewPager
                            android:id="@+id/pager"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_above="@+id/rg_video_type_bottoms"
                            android:layout_below="@id/ll_rb"
                            android:layout_marginRight="@dimen/sm_30"
                            android:layout_weight="1"
                            android:clipToPadding="false"
                            android:paddingTop="@dimen/sm_10"
                            android:paddingBottom="@dimen/sm_20" />
                    </LinearLayout>




                </LinearLayout>



            <!--弹窗公告 - 优化样式-->
            <RelativeLayout
                android:id="@+id/notice"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:background="#CC000000"
                android:gravity="center"
                android:visibility="visible"
                android:clickable="true">

                <ImageView
                    android:id="@+id/notice_iamge_url"
                    android:layout_width="@dimen/sm_900"
                    android:layout_height="@dimen/sm_600"
                    android:layout_centerInParent="true"
                    android:scaleType="fitCenter"
                    android:background="@drawable/notice_bg" />

                <TextView
                    android:id="@+id/notice_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignRight="@id/notice_iamge_url"
                    android:layout_alignBottom="@id/notice_iamge_url"
                    android:layout_marginRight="@dimen/sm_25"
                    android:layout_marginBottom="@dimen/sm_25"
                    android:paddingLeft="@dimen/sm_35"
                    android:paddingRight="@dimen/sm_35"
                    android:paddingTop="@dimen/sm_12"
                    android:paddingBottom="@dimen/sm_12"
                    android:background="@drawable/button_1"
                    android:text="@string/returns"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sm_24"
                    android:visibility="gone" />
            </RelativeLayout>

        </RelativeLayout>
    </FrameLayout>
    <!--应用更新提示 - 优化位置-->
    <TextView
        android:id="@+id/tv_update_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sm_100"
        android:layout_gravity="center_horizontal"
        android:paddingLeft="@dimen/sm_20"
        android:paddingRight="@dimen/sm_20"
        android:paddingTop="@dimen/sm_10"
        android:paddingBottom="@dimen/sm_10"
        android:background="@drawable/update_msg_bg"
        android:textColor="@color/detail_point"
        android:textSize="@dimen/sm_22" />
</FrameLayout>